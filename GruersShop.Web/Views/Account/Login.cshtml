@using GruersShop.Web.ViewModels.Account.Profile;
@model LoginViewModel
@{
    ViewData["Title"] = "Welcome Back";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="warm-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <i class="bi bi-egg-fried display-1 text-warm"></i>
                    <h1 class="display-5 mt-2">Welcome Back</h1>
                    <div class="honey-accent mx-auto"></div>
                    <p class="text-muted mt-3">Sign in to continue your journey</p>
                </div>

             

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text stone-input-prepend">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control warm-input" placeholder="your@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text stone-input-prepend">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control warm-input" placeholder="Enter your password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input warm-checkbox" />
                        <label asp-for="RememberMe" class="form-check-label">Remember Me</label>
                    </div>

                    <button type="submit" class="btn-glow w-100 py-2 mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
                    </button>

                    <div class="text-center position-relative my-3">
                        <hr class="stone-divider">
                        <span class="px-3 small text-muted bg-transparent">or</span>
                    </div>

                    <a asp-action="Register" class="btn-warm w-100 py-2 mb-2">
                        <i class="bi bi-person-plus me-2"></i> Create Account
                    </a>

                    <div class="text-center mt-3">
                        <a asp-action="ForgotPassword" class="text-warm text-decoration-none small">
                            <i class="bi bi-key me-1"></i> Forgot your password?
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}