@using GruersShop.Web.ViewModels.Account.Profile;
@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card p-5 rounded-4 shadow-lg">
                <div class="text-center mb-4">
                    <div class="glass-icon-circle mx-auto mb-3">
                        <i class="bi bi-key fs-1" style="color: #c09a6c;"></i>
                    </div>
                    <h2 class="fw-bold mb-2">Forgot Password?</h2>
                    <p class="text-muted">Enter your email to reset your password</p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text glass-input-prepend">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control glass-input" placeholder="your@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary-glass py-2">
                            <i class="bi bi-send me-2"></i> Send Reset Link
                        </button>
                        <a asp-action="Login" class="btn btn-outline-glass py-2">
                            <i class="bi bi-arrow-left me-2"></i> Back to Login
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}