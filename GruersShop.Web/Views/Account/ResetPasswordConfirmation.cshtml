@{
    ViewData["Title"] = "Password Reset";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card p-5 rounded-4 shadow-lg text-center">
                <div class="glass-icon-circle mx-auto mb-3">
                    <i class="bi bi-check-circle fs-1" style="color: #28a745;"></i>
                </div>
                <h2 class="fw-bold mb-3">Password Reset Successfully!</h2>
                <p class="text-muted mb-4">
                    Your password has been reset. You can now log in with your new password.
                </p>
                <a asp-action="Login" class="btn btn-primary-glass">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Login Now
                </a>
            </div>
        </div>
    </div>
</div>