@model GruersShop.Web.ViewModels.Account.Profile.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset Your Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="warm-card p-4 p-md-5 text-center">
                <i class="bi bi-key display-1 text-warm"></i>
                <h1 class="display-5 mt-2">Forgot Password?</h1>
                <div class="honey-accent mx-auto"></div>
                <p class="text-muted mt-3">Enter your email address and we'll send you a link to reset your password.</p>

                <form asp-action="ForgotPassword" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold text-start d-block">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text stone-input-prepend">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control warm-input" placeholder="your@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn-glow w-100 py-2 mb-3">
                        <i class="bi bi-send me-2"></i> Send Reset Link
                    </button>

                    <a asp-action="Login" class="btn-warm w-100 py-2">
                        <i class="bi bi-arrow-left me-2"></i> Back to Login
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}