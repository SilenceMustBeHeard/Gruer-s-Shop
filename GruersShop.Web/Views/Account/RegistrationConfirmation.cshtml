@{
    ViewData["Title"] = "Confirm Your Email";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="warm-card p-5">
                <i class="bi bi-envelope-paper display-1 text-warm"></i>
                <h2 class="mt-3">Check Your Email 📧</h2>
                <p class="text-muted">
                    We've sent a confirmation link to your email address.<br>
                    Please click the link to activate your account.
                </p>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn-warm-sm">
                        <i class="bi bi-house-heart me-1"></i> Return Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>