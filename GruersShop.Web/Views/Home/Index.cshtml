@using GruersShop.Data.Common.Enums
@model GruersShop.Web.ViewModels.Home.HomeViewModel

@{
    ViewData["Title"] = "Gruer's Artisanal Bakery";
}

<!-- Hero Section -->
<div class="hero-oven text-center text-white mb-5">
    <div class="container">
        <i class="bi bi-egg-fried display-1 mb-3 d-block"></i>
        <h1 class="display-3 mb-3">Gruer's Artisanal Bakery</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="lead mx-auto mt-4 story-text" style="max-width: 600px; color: #e8d9cc;">
            "Where every bite tells a story — crafted with warmth, kissed by magic, and baked to perfection."
        </p>
        <div class="mt-4">
            <a asp-controller="Catalog" asp-action="Index" class="btn-glow me-2">
                <i class="bi bi-shop me-1"></i> Visit Bakery
            </a>
            <a asp-controller="Home" asp-action="About" class="btn-warm">
                <i class="bi bi-book-heart me-1"></i> Gruer's Story
            </a>
        </div>
    </div>
</div>

<!-- Fresh from the Oven Section -->
<div class="container my-5">
    <h2 class="text-center mb-4">Fresh from the Oven</h2>
    <div class="honey-accent mx-auto mb-5"></div>
    
    @if (Model.TopRatedProducts.Any())
    {
        <div class="row g-4">
            @foreach (var product in Model.TopRatedProducts)
            {
                <div class="col-md-4">
                    <div class="product-card h-100">
                        <div class="product-card-image">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" style="width: 100%; height: 400px; object-fit: cover; border-radius: 9px 9px 0 0;" />
                            }
                            else
                            {
                                <i class="bi bi-cup-hot display-1 text-white-50"></i>
                            }
                        </div>
                        <div class="product-card-content">
                            <h3 class="product-card-title mb-2">@product.Name</h3>
                            <p class="text-muted small">@(product.Description?.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-egg-fried display-2 text-muted"></i>
            <p class="mt-3">No products available yet. Check back soon!</p>
        </div>
    }
</div>

<!-- Gruer's Story Quote -->
<div class="container my-5">
    <div class="warm-card text-center">
        <i class="bi bi-quote display-4 text-warm"></i>
        <p class="story-text mx-auto" style="max-width: 700px; font-size: 1.2rem; font-style: italic;">
            "I have dreamed of this shop for decades. A place where ordinary people can taste other worlds.
            Where every bite tells a story — of warmth, of wonder, of the magic that brought me here."
        </p>
        <footer class="blockquote-footer mt-3">— Gruer, Master Baker</footer>
        <div class="honey-accent mx-auto mt-4"></div>
    </div>
</div>

<!-- Featured Categories -->
<div class="container my-5">
    <h2 class="text-center mb-4">Our Specialties</h2>
    <div class="honey-accent mx-auto mb-5"></div>
    
    @if (Model.Categories.Any())
    {
        <div class="row g-4 text-center">
            @foreach (var category in Model.Categories)
            {
                <div class="col-md-3">
                    <div class="warm-card p-3 h-100">
                        <i class="bi display-4 text-warm category-icon" data-category="@category.Name"></i>
                        <h4 class="mt-2">@category.Name</h4>
                        @if (!string.IsNullOrEmpty(category.Description))
                        {
                            <small class="text-muted">@(category.Description.Length > 40 ? category.Description.Substring(0, 40) + "..." : category.Description)</small>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <p class="text-muted">Categories coming soon...</p>
        </div>
    }
</div>

<!-- Call to Action -->
<div class="container my-5">
    <div class="hero-oven text-center text-white py-5">
        <h2 class="mb-3">Ready to Taste the Magic?</h2>
        <div class="honey-accent mx-auto"></div>
        <p class="mb-4 mt-3">Visit us today and experience flavors from across the worlds.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn-glow btn-lg">
            <i class="bi bi-shop me-2"></i> Explore Our Bakery
        </a>
    </div>
</div>



<script>
    // function to determine icon class based on category name
    function getCategoryIcon(categoryName) {
        const name = categoryName?.toLowerCase() || '';
        
        if (name.includes('bread')) return 'bi-bread';
        if (name.includes('pastry') || name.includes('croissant')) return 'bi-cake2';
        if (name.includes('drink') || name.includes('coffee') || name.includes('tea')) return 'bi-cup-straw';
        if (name.includes('cake') || name.includes('tart')) return 'bi-cake';
        if (name.includes('cookie')) return 'bi-egg-fried';
        if (name.includes('seasonal') || name.includes('special')) return 'bi-gem';
        
        return 'bi-shop';
    }
    
    // load icons after DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
        const categoryIcons = document.querySelectorAll('.category-icon');
        
        categoryIcons.forEach(icon => {
            const categoryName = icon.getAttribute('data-category');
            const iconClass = getCategoryIcon(categoryName);
            icon.className = `bi ${iconClass} display-4 text-warm category-icon`;
        });
        
        console.log('🍰 Home page loaded - static display only');
    });
</script>