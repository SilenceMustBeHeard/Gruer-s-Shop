@using GruersShop.Data.Common.Enums
@using GruersShop.Data.Models.Interactions
@model Order

@{
    ViewData["Title"] = $"Order #{Model.Id.ToString().Substring(0, 8)}";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <a asp-action="MyOrders" class="btn-warm-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back to My Orders
            </a>
            
            <div class="warm-card p-4">
                <!-- Order Header -->
                <div class="text-center mb-4">
                    <i class="bi bi-receipt display-1 text-warm"></i>
                    <h1 class="display-5 mt-2">Order Details</h1>
                    <div class="honey-accent mx-auto"></div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4 pb-3 border-bottom">
                    <div>
                        <span class="text-muted">Order #</span>
                        <span class="fw-bold">@Model.Id.ToString().Substring(0, 8)</span>
                    </div>
                    <div>
                        <span class="text-muted">Placed on</span>
                        <span class="fw-bold">@Model.OrderDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div>
                        <span class="status-badge @GetStatusClass(Model.Status)">@GetStatusText(Model.Status)</span>
                    </div>
                </div>
                
                <!-- Order Items -->
                <h4 class="fw-bold mb-3">Items</h4>
                <div class="table-responsive mb-4">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-muted">
                                <th>Product</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;">
                                            <div>
                                                <h6 class="fw-bold mb-0">@item.Product?.Name</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end fw-bold">@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                <td class="text-end fw-bold fs-5 text-warm">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                
                <!-- Pickup Info -->
                <h4 class="fw-bold mb-3">Pickup Information</h4>
                <div class="warm-card p-3 mb-4">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Pickup Date</small>
                            <p class="fw-bold mb-0">@Model.PickupDate?.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Pickup Time</small>
                            <p class="fw-bold mb-0">@Model.PickupTime</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                    {
                        <div class="mt-2">
                            <small class="text-muted">Special Instructions</small>
                            <p class="mb-0">@Model.SpecialInstructions</p>
                        </div>
                    }
                </div>
                
                <!-- Action Buttons -->
                @if (Model.Status == OrderStatus.Pending)
                {
                    <div class="d-flex justify-content-end">
                        <form asp-action="Cancel" method="post" onsubmit="return confirm('Are you sure you want to cancel this order?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn-warm-sm" style="background: #dc3545;">
                                <i class="bi bi-x-circle me-1"></i> Cancel Order
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "status-pending",
        OrderStatus.Confirmed => "status-confirmed",
        OrderStatus.Baking => "status-baking",
        OrderStatus.ReadyForPickup => "status-ready",
        OrderStatus.Completed => "status-completed",
        OrderStatus.Cancelled => "status-cancelled",
        _ => "status-pending"
    };
    
    string GetStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Pending",
        OrderStatus.Confirmed => "Confirmed",
        OrderStatus.Baking => "Baking",
        OrderStatus.ReadyForPickup => "Ready for Pickup",
        OrderStatus.Completed => "Completed",
        OrderStatus.Cancelled => "Cancelled",
        _ => "Pending"
    };
}