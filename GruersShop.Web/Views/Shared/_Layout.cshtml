<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gruer's Shop</title>
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- Google Fonts for warm typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Theme styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/badges.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/navigation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/error.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/dark.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/light.css" asp-append-version="true" />

</head>

<body>
    <canvas id="sparksCanvas"></canvas>
    <header>
        <!-- Reshaped Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark py-2">
            <div class="container">
                <!-- Logo / Brand - Restyled -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-egg-fried fs-2 text-warm"></i>
                        <div>
                            <span class="brand-baked">Gruer’s</span>
                            <span class="brand-subtitle">Artisanal Bakery</span>
                        </div>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Center Navigation - Centered properly -->
                    <div class="mx-auto d-flex justify-content-center">
                        @await Component.InvokeAsync("Navbar")
                    </div>

                    <!-- Right Side - Account area -->
                    <div class="d-flex gap-2 align-items-center">
                        <!-- Account Dropdown -->
                        <div class="dropdown">
                            <button class="btn-warm dropdown-toggle d-flex align-items-center gap-1" data-bs-toggle="dropdown" style="padding: 0.4rem 1rem;">
                                <i class="bi bi-person-circle"></i>
                                <span>Account</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="min-width: 220px;">
                                @await Component.InvokeAsync("AccountMenu")
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Oven Glow Alert Messages -->
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert-oven alert-success" role="alert">
                    <i class="bi bi-fire me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close-oven" data-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert-oven alert-danger" role="alert">
                    <i class="bi bi-emoji-frown me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close-oven" data-dismiss="alert"></button>
                </div>
            }
        </div>
    </header>

    <!-- Main Content - Warm Hearth -->
    <main class="hearth-container">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <!-- Footer - Warm Stone -->
    <footer class="footer-stone mt-auto py-4">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year - Gruer's Artisanal Bakery</p>
            <small class="text-muted">"Where every bite tells a story"</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/oven.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>