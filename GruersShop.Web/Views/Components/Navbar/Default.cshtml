
@using GruersShop.Web.ViewModels.Account.Profile
@model NavbarButtonsViewModel

<div class="d-flex align-items-center gap-2">

    @* Role mode indicator *@
    @if (Model.IsAdmin || Model.IsManager)
    {
        <div class="glass-caption @(Model.IsAdmin ? "admin-glow" : "manager-glow")">
            <i class="bi @(Model.IsAdmin ? "bi-shield-lock-fill" : "bi-person-badge-fill") me-2"></i>
            <span>@(Model.IsAdmin ? "ADMIN" : "MANAGER") MODE</span>
            <span class="mode-separator">|</span>
            <span class="mode-area">
                <i class="bi bi-diagram-3 me-1"></i>@Model.CurrentArea
            </span>
        </div>
    }

    @if (Model.IsAdmin)
    {
        <a class="btn btn-outline-glass btn-sm"
           asp-area="Admin"
           asp-controller="Home"
           asp-action="Index">
            Admin Panel
        </a>

        <a class="btn btn-outline-glass"
           asp-area="Admin"
           asp-controller="OrdersManagement"
           asp-action="Manage">
            <span>Orders</span>
            @if (Model.PendingOrdersCount > 0)
            {
                <span class="badge bg-warning text-dark rounded-pill">
                    @Model.PendingOrdersCount
                </span>
            }
        </a>

        <a class="btn btn-outline-glass d-flex align-items-center gap-2"
           asp-area="Admin"
           asp-controller="AdminProfile"
           asp-action="AdminInbox">
            <i class="bi bi-envelope"></i>
            <span>Messages</span>
            @if (Model.UnreadMessagesCount > 0)
            {
                <span class="badge bg-warning text-dark rounded-pill">
                    @Model.UnreadMessagesCount
                </span>
            }
        </a>

        <a class="btn btn-primary-glass"
           asp-area="Admin"
           asp-controller="CatalogManagement"
           asp-action="AdminIndex">
            Catalogue
        </a>
    }
    else if (Model.IsManager)
    {
        <a asp-area="Manager"
           class="btn btn-primary-glass"
           asp-controller="Catalog"
           asp-action="CatalogIndex">
            Catalogue
        </a>

        <a asp-area="Manager"
           class="btn btn-outline-glass"
           asp-controller="OrdersManagement"
           asp-action="Manage">
            Orders (@Model.PendingOrdersCount)
        </a>

        <a asp-area="Manager"
               class="btn btn-outline-glass d-flex align-items-center gap-2"
               asp-controller="ManagerProfile"
               asp-action="Index">
            <i class="bi bi-envelope"></i>
            <span>Messages</span>
            @if (Model.UnreadMessagesCount > 0)
            {
                <span class="badge bg-warning text-dark rounded-pill">
                    @Model.UnreadMessagesCount
                </span>
            }
        </a>
    }
    else if (Model.IsUser)
    {
        @* Registered User *@

        <a class="btn btn-primary-glass position-relative"
               asp-controller="ContactMessage"
               asp-action="Index">
            <i class="bi bi-envelope me-2"></i>Contact Us
        </a>

        <a class="btn btn-primary-glass position-relative"
           asp-controller="Catalog"
           asp-action="CatalogIndex">
            Catalogue
        </a>

        <a class="btn btn-outline-glass"
           asp-controller="Orders"
           asp-action="Create">
            New Order
        </a>

        <a class="btn btn-outline-glass d-flex align-items-center gap-2"
           asp-controller="Profile"
           asp-action="Index">
            <i class="bi bi-envelope"></i>
            @if (Model.UnreadMessagesCount > 0)
            {
                <span class="badge bg-warning text-dark rounded-pill">
                    @Model.UnreadMessagesCount
                    
                </span>
            }
        </a>
    }
</div>

