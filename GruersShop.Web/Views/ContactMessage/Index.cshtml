@model GruersShop.Web.ViewModels.Account.Messages.ContactMessageCreateViewModel

@{
    ViewData["Title"] = "Contact Us";
}


<div class="card glass-card p-4 ">

<div class="container py-5">
    <div class="row g-4">
        
        @* Left side - Contact Info Cards *@
        <div class="col-lg-4">
            <div class="glass-card p-4 rounded-4 h-100">
                <div class="text-center mb-4">
                    <div class="glass-icon-circle mx-auto mb-3">
                        <i class="bi bi-headset fs-1" style="color: #c09a6c;"></i>
                    </div>
                    <h4 class="fw-bold mb-1">Contact Information</h4>
                    <p class="text-muted small">We're here to help</p>
                </div>

                <div class="contact-info-card mb-3 p-3 rounded-3">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="bi bi-envelope-fill fs-4" style="color: #c09a6c;"></i>
                        </div>
                        <div class="flex-grow-1">
                            <small class="text-muted d-block">Email Us</small>
                            <a href="mailto:support@gruersshop.com" class="text-decoration-none" style="color: #c09a6c;">
                                support@gruersshop.com
                            </a>
                        </div>
                    </div>
                </div>

                <div class="contact-info-card mb-3 p-3 rounded-3">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="bi bi-clock-fill fs-4" style="color: #c09a6c;"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Business Hours</small>
                            <span>Mon-Fri: 9AM - 6PM</span>
                        </div>
                    </div>
                </div>

                <div class="contact-info-card p-3 rounded-3">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="bi bi-chat-dots-fill fs-4" style="color: #c09a6c;"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Response Time</small>
                            <span>Average response: 24h</span>
                        </div>
                    </div>
                </div>

                <hr class="border-light opacity-25 my-4" />

                <div class="text-center">
                    <i class="bi bi-shield-check fs-1 opacity-50" style="color: #c09a6c;"></i>
                    <p class="small text-muted mt-2">Your message is secure and will be answered within 24 hours.</p>
                </div>
            </div>
        </div>

        @* Right side - Contact Form *@
        <div class="col-lg-8">
            <div class="glass-card p-4 p-md-5 rounded-4">

                @* Header with icon *@
                <div class="text-center mb-4">
                    <div class="glass-icon-circle mx-auto mb-3">
                        <i class="bi bi-chat-dots-fill fs-1" style="color: #c09a6c;"></i>
                    </div>
                    <h2 class="fw-bold mb-2 hero-title">Send us a Message</h2>
                    <p class="text-muted small">
                        Have a question or feedback? We'd love to hear from you!
                    </p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        @* Subject field *@
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="Subject" class="form-label fw-semibold">
                                    <i class="bi bi-tag me-1" style="color: #c09a6c;"></i> Subject
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text glass-input-prepend">
                                        <i class="bi bi-chat-text"></i>
                                    </span>
                                    <input asp-for="Subject" class="form-control glass-input" placeholder="e.g., Question about my order, Feedback, Support" />
                                </div>
                                <span asp-validation-for="Subject" class="text-danger small"></span>
                            </div>
                        </div>

                        @* Message field *@
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="Message" class="form-label fw-semibold">
                                    <i class="bi bi-envelope me-1" style="color: #c09a6c;"></i> Message
                                </label>
                                <textarea asp-for="Message" class="form-control glass-input" rows="6"
                                          placeholder="Type your message here. Be as detailed as possible so we can assist you better..."></textarea>
                                <span asp-validation-for="Message" class="text-danger small"></span>
                                <small class="text-muted d-block mt-1">
                                    <i class="bi bi-info-circle me-1"></i> Minimum 10 characters
                                </small>
                            </div>
                        </div>
                    </div>

                    @* Action Buttons *@
                    <div class="d-flex gap-3 justify-content-center mt-4">
                        <button type="submit" class="btn btn-primary-glass px-5 py-2">
                            <i class="bi bi-send me-2"></i> Send Message
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-glass px-4 py-2">
                            <i class="bi bi-arrow-left me-2"></i> Back to Home
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

