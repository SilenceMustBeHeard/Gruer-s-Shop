@using GruersShop.Data.Common.Enums
@using GruersShop.Web.ViewModels.Account.Messages
@model SystemInboxMessageViewModel

@{
    ViewData["Title"] = "A Letter from Gruer's";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-controller="Profile" asp-action="Index" class="btn-warm-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back to my corner
            </a>

            <div class="warm-card" style="background: url('data:image/svg+xml;utf8,<svg xmlns=\" http: //www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"%23c4b6a510\">
              
                <div class="text-center mb-4">
                    <i class="bi bi-megaphone display-3 text-warm"></i>
                    <div class="honey-accent mx-auto"></div>
                    <div class="mt-2">
                        @if (!Model.IsRead)
                        {
                            <span class="honey-badge">Fresh from the oven</span>
                        }
                    </div>
                </div>

                <div class="letter-header text-center mb-4">
                    <h1 class="display-5 fw-bold">@Model.Title</h1>
                    <p class="text-muted">
                        <i class="bi bi-calendar-heart me-1"></i>
                        @Model.CreatedOn.ToLocalTime().ToString("dddd, dd MMMM yyyy")
                    </p>
                </div>

                <div class="story-text" style="font-size: 1.05rem; line-height: 1.8;">
                    <p>@Model.Description</p>
                </div>

                <div class="letter-footer text-center mt-5 pt-3">
                    <div class="honey-accent mx-auto"></div>
                    <p class="small text-muted mt-3">
                        <i class="bi bi-suit-heart-fill text-warm"></i>
                        With warmth from Gruer's Bakery
                    </p>
                </div>

                <hr class="stone-divider my-4">

                <div class="d-flex justify-content-center">
                    <a asp-controller="Profile" asp-action="Index" class="btn-glow">
                        <i class="bi bi-envelope-open me-1"></i> Back to my corner
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>