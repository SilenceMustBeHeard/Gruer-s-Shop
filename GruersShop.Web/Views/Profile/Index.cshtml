@using GruersShop.Web.ViewModels.Account.Profile;
@model ProfileViewModel

@{
    ViewData["Title"] = "My Corner - Gruer's Bakery";
}

<div class="container py-5">
    <!-- Welcome Banner - Like a warm greeting at the counter -->
    <div class="hero-oven text-center mb-5">
        <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
            <i class="bi bi-cup-hot display-4"></i>
            <i class="bi bi-heart-fill text-warm"></i>
            <i class="bi bi-egg-fried display-4"></i>
        </div>
        <h1 class="display-4">Welcome back, @Model.FirstName! 🥐</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="mt-3">Your corner of warmth and stories</p>
    </div>

    <div class="row g-5">
        <!-- Recipe Card - User Info (Like a handwritten recipe card) -->
        <div class="col-lg-4">
            <div class="warm-card text-center p-4">
                <div class="mb-4">
                    <div style="width: 120px;
                        height: 120px; background:
                        linear-gradient(135deg, var(--wood-light),
                        var(--wood-medium)); border-radius: 50%; display:
                        inline-flex; align-items: center;
                        justify-content: center;">
                        <i class="bi bi-person display-1 text-white"></i>
                    </div>
                </div>
                <h3 class="fw-bold">@Model.FirstName @Model.LastName</h3>
                <div class="honey-accent mx-auto" style="width: 40px;"></div>
                
                <div class="mt-4 text-start">
                    <div class="mb-3">
                        <small class="text-muted">Email</small>
                        <p class="mb-0"><i class="bi bi-envelope me-2 text-warm"></i> @Model.Email</p>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">Location</small>
                        <p class="mb-0"><i class="bi bi-geo-alt me-2 text-warm"></i> @(string.IsNullOrEmpty(Model.Address) ? "Not shared yet" : Model.Address)</p>
                    </div>
                    <div>
                        <small class="text-muted">Member since</small>
                        <p class="mb-0"><i class="bi bi-calendar-heart me-2 text-warm"></i> A loyal member of our family</p>
                    </div>
                </div>

                <hr class="stone-divider my-4">

                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-warm w-100">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </button>
                </form>

            </div>
        </div>

        <!-- Letters Section - Like a tray of letters -->
        <div class="col-lg-8">
            <div class="warm-card p-4">
                <div class="d-flex gap-3 border-bottom pb-3 mb-4">
                    <button class="btn-warm-sm active-tab px-3 py-2" id="systemTabBtn">
                        <i class="bi bi-megaphone me-1"></i> News & Updates
                        @if (Model.SystemInbox?.Count(x => !x.IsRead) > 0)
                        {
                            <span class="honey-badge ms-1">@Model.SystemInbox.Count(x => !x.IsRead)</span>
                        }
                    </button>
                    <button class="btn-stone-sm px-3 py-2" id="contactTabBtn">
                        <i class="bi bi-chat-heart me-1"></i> Your Letters
                        @if (Model.ContactMessages?.Count(x => !x.IsRead) > 0)
                        {
                            <span class="honey-badge ms-1">@Model.ContactMessages.Count(x => !x.IsRead)</span>
                        }
                    </button>
                </div>

                <!-- System Messages - Like community announcements -->
                <div id="systemMessagesPanel">
                    @if (Model.SystemInbox == null || !Model.SystemInbox.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-envelope-open display-4 text-muted"></i>
                            <p class="mt-3">No announcements yet</p>
                            <p class="small text-muted">When Gruer shares news, you'll find them here</p>
                        </div>
                    }
                    else
                    {
                        <div class="letters-stack">
                            @foreach (var message in Model.SystemInbox.OrderByDescending(x => x.CreatedOn))
                            {
                                <div class="letter-item mb-4 p-3">
                                    <a asp-controller="Profile" asp-action="SystemMessageDetails" asp-route-id="@message.Id" class="letter-link">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-megaphone text-warm fs-4"></i>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@message.Title</h6>
                                                    <small class="text-muted">@message.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</small>
                                                </div>
                                            </div>
                                            @if (!message.IsRead)
                                            {
                                                <span class="honey-badge">Fresh</span>
                                            }
                                        </div>
                                        <p class="mt-2 mb-0 small text-muted">@(message.Description.Length > 100 ? message.Description.Substring(0, 100) + "..." : message.Description)</p>
                                        <div class="mt-2">
                                            <span class="read-more-link">Read letter <i class="bi bi-arrow-right"></i></span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Contact Messages - Like letters from customers -->
                <div id="contactMessagesPanel" style="display: none;">
                    @if (Model.ContactMessages == null || !Model.ContactMessages.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-envelope-paper display-4 text-muted"></i>
                            <p class="mt-3">No letters yet</p>
                            <p class="small text-muted">Write to Gruer and his team</p>
                            <a asp-controller="ContactMessage" asp-action="Index" class="btn-glow-sm mt-2">
                                <i class="bi bi-pencil me-1"></i> Write a letter
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="letters-stack">
                            @foreach (var message in Model.ContactMessages.OrderByDescending(x => x.CreatedOn))
                            {
                                <div class="letter-item mb-4 p-3">
                                    <a asp-controller="Profile" asp-action="ContactMessageDetails" asp-route-id="@message.Id" class="letter-link">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-chat-heart text-warm fs-4"></i>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@message.Subject</h6>
                                                    <small class="text-muted">@message.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</small>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(message.Response))
                                            {
                                                <span class="stone-badge">Replied</span>
                                            }
                                            else
                                            {
                                                <span class="honey-badge">Waiting</span>
                                            }
                                        </div>
                                        <p class="mt-2 mb-0 small text-muted">@(message.Message.Length > 100 ? message.Message.Substring(0, 100) + "..." : message.Message)</p>
                                        <div class="mt-2">
                                            <span class="read-more-link">Read letter <i class="bi bi-arrow-right"></i></span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Wait for page to load
    document.addEventListener('DOMContentLoaded', function() {
        const systemTab = document.getElementById('systemTabBtn');
        const contactTab = document.getElementById('contactTabBtn');
        const systemPanel = document.getElementById('systemMessagesPanel');
        const contactPanel = document.getElementById('contactMessagesPanel');
        
        // System tab click handler
        systemTab.onclick = function() {
            systemTab.className = 'btn-warm-sm active-tab px-3 py-2';
            contactTab.className = 'btn-stone-sm px-3 py-2';
            systemPanel.style.display = 'block';
            contactPanel.style.display = 'none';
        };
        
        // Contact tab click handler
        contactTab.onclick = function() {
            contactTab.className = 'btn-warm-sm active-tab px-3 py-2';
            systemTab.className = 'btn-stone-sm px-3 py-2';
            systemPanel.style.display = 'none';
            contactPanel.style.display = 'block';
        };
        
        // Set initial state
        systemTab.className = 'btn-warm-sm active-tab px-3 py-2';
        contactTab.className = 'btn-stone-sm px-3 py-2';
        systemPanel.style.display = 'block';
        contactPanel.style.display = 'none';
    });
</script>