@using GruersShop.Web.ViewModels.Account.Messages;
@model ContactMessageDetailsViewModel

<a asp-controller="Profile"
       asp-action="ContactMessageDetails"
       asp-route-id="@Model.Id"
       class="text-decoration-none">

    <div class="glass-list-item p-3 mb-3 message-card @(Model.IsRead ? "read" : "unread")">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="d-flex align-items-center gap-2">
                <div class="status-dot @(Model.IsRead ? "bg-secondary" : "bg-warning")"></div>
                <small class="text-muted">
                    @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy · HH:mm")
                </small>
                <span class="badge bg-info ms-2">Sent</span>
                @if (!string.IsNullOrEmpty(Model.Response))
                {
                    <span class="badge bg-success ms-2">Replied</span>
                }
            </div>
            @if (!Model.IsRead)
            {
                <span class="unread-badge">New Response</span>
            }
        </div>

        <div class="mb-2">
            <strong class="text-light">@Model.Subject</strong>
        </div>

        <p class="text-light mb-2 message-preview">
            @(Model.Message.Length > 100 ? Model.Message.Substring(0, 100) + "..." : Model.Message)
        </p>

        @if (!string.IsNullOrEmpty(Model.Response))
        {
            <div class="small text-success mb-2">
                <i class="bi bi-check-circle me-1"></i>
                Response: @(Model.Response.Length > 80 ? Model.Response.Substring(0, 80) + "..." : Model.Response)
            </div>
            <div class="small text-muted mb-2">
                <i class="bi bi-clock me-1"></i>Replied on @Model.RespondedOnFormatted
            </div>
        }
        else
        {
            <div class="small text-muted mb-2">
                <i class="bi bi-clock me-1"></i>Awaiting response
            </div>
        }

        <div class="d-flex gap-2" onclick="event.stopPropagation()">
            <a asp-controller="Profile"
                   asp-action="ContactMessageDetails"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary-glass btn-sm w-100">
                <i class="bi bi-envelope-open me-1"></i>@(!string.IsNullOrEmpty(Model.Response) ? "Read Response" : "View Message")
            </a>
        </div>
    </div>
</a>