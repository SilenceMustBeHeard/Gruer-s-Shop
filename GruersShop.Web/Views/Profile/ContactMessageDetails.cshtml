@using GruersShop.Web.ViewModels.Admin.Message;
@model ContactMessageDetailsViewModel

@{
    ViewData["Title"] = "Your Letter to Gruer's";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-controller="Profile" asp-action="Index" class="btn-warm-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back to my corner
            </a>

            <div class="warm-card p-4">
                <!-- Your Letter Section -->
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-pencil-fill text-warm"></i>
                        <h5 class="mb-0 fw-bold">Your Letter</h5>
                    </div>

                    <div class="stone-badge mb-3">
                        <i class="bi bi-clock me-1"></i>
                        @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy · hh:mm tt")
                    </div>

                    <div class="story-text p-3" style="background: rgba(107, 140, 66, 0.1); border-left: 4px solid var(--leaf-green); border-radius: 12px; word-wrap: break-word; overflow-wrap: break-word;">
                        <h3 class="fw-bold mb-3">@Model.Subject</h3>
                        <p class="mb-0" style="white-space: pre-wrap; word-wrap: break-word; overflow-wrap: break-word;">@Model.Message</p>
                    </div>
                </div>

                <!-- Reply from Bakery Section -->
                @if (!string.IsNullOrEmpty(Model.Response))
                {
                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-reply-all-fill text-leaf"></i>
                            <h5 class="mb-0 fw-bold">Gruer's Reply</h5>
                        </div>

                        <div class="stone-badge mb-3">
                            <i class="bi bi-calendar-check me-1"></i>
                            @Model.RespondedOnFormatted
                            @if (!string.IsNullOrEmpty(Model.RespondedByName))
                            {
                                <span class="ms-2">
                                    <i class="bi bi-person me-1"></i> @Model.RespondedByName
                                </span>
                            }
                        </div>

                        <div class="story-text p-3" style="background: rgba(107, 140, 66, 0.1); border-left: 4px solid var(--leaf-green); border-radius: 12px; word-wrap: break-word; overflow-wrap: break-word;">
                            <p style="white-space: pre-wrap; word-wrap: break-word; overflow-wrap: break-word;">@Model.Response</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 warm-card">
                        <i class="bi bi-hourglass-split display-4 text-muted"></i>
                        <p class="mt-3 mb-0 fw-semibold">Your letter is waiting to be read</p>
                        <p class="small text-muted mt-1">Gruer and the team will reply soon with warmth</p>
                    </div>
                }

                <hr class="stone-divider my-4">

                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a asp-controller="Profile" asp-action="Index" class="btn-glow">
                        <i class="bi bi-house-heart me-1"></i> Return to my corner
                    </a>
                    @if (string.IsNullOrEmpty(Model.Response))
                    {
                        <a asp-controller="ContactMessage" asp-action="Index" class="btn-warm">
                            <i class="bi bi-pencil me-1"></i> Write another letter
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .response-card {
        border-radius: 16px;
    }

    .text-leaf {
        color: var(--leaf-green);
    }
</style>