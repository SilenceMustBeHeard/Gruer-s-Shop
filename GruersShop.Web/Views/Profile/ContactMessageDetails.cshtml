@using GruersShop.Web.ViewModels.Account.Messages;
@model ContactMessageDetailsViewModel

@{
    ViewData["Title"] = "Contact Message Details";
}

<div class="container py-5">
    <div class="card glass-card p-5 text-light shadow-lg border-0 rounded-4">

        <a asp-controller="Profile"
           asp-action="Index"
           class="btn btn-outline-glass mb-4">
            ← Back to Profile
        </a>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-1">Contact Message</h2>
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <span class="badge bg-info">Sent by you</span>
                            @if (!string.IsNullOrEmpty(Model.Response))
                            {
                                if (!Model.IsRead)
                                {
                                    <span class="badge bg-warning text-dark pulse-badge">New Response!</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Response Read</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Awaiting Response</span>
                            }
                        </div>
                    </div>
                    <small class="text-muted">
                        @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </small>
                </div>

                <hr class="border-light opacity-25" />

                <div class="mb-4">
                    <h6 class="text-warning mb-3">Subject</h6>
                    <div class="glass-card p-3">
                        <p class="text-light mb-0">@Model.Subject</p>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="text-warning mb-3">Your Message</h6>
                    <div class="glass-card p-3">
                        <p class="text-light mb-0" style="white-space: pre-wrap;">@Model.Message</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Response))
                {
                    <div class="mb-4">
                        <h6 class="text-success mb-3">Admin Response</h6>
                        <div class="glass-card p-3" style="border-left: 3px solid #28a745;">
                            <p class="text-light mb-2" style="white-space: pre-wrap;">@Model.Response</p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted">
                                    <i class="bi bi-reply-all me-1"></i>Responded on @Model.RespondedOnFormatted
                                </small>
                                @if (!string.IsNullOrEmpty(Model.RespondedByName))
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-person me-1"></i>By: @Model.RespondedByName
                                    </small>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!Model.IsRead)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            This response is marked as read automatically when you view it.
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Your message has been sent. An admin will respond shortly.
                    </div>
                }

                <div class="d-flex justify-content-end mt-4">
                    <a asp-controller="Profile"
                       asp-action="Index"
                       class="btn btn-primary-glass">
                        <i class="bi bi-check2-circle me-2"></i>Done
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

