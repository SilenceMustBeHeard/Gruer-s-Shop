@using GruersShop.Web.ViewModels.Admin.Message;
@model ContactMessageDetailsViewModel

@{
    ViewData["Title"] = "Your Letter to Gruer's";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-controller="Profile" asp-action="Index" class="btn-warm-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back to my corner
            </a>

            <div class="warm-card">
                <!-- Your Letter -->
                <div class="mb-4">
                    <div class="text-center mb-3">
                        <i class="bi bi-pencil display-3 text-warm"></i>
                        <h5 class="mt-2">Your Letter</h5>
                        <div class="honey-accent mx-auto" style="width: 40px;"></div>
                    </div>
                    <div class="story-text" style="background: var(--stone-light); padding: 1.5rem; border-radius: 16px;">
                        <h3 class="fw-bold mb-3">@Model.Subject</h3>
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.Message</p>
                        <p class="text-muted small mt-3">
                            <i class="bi bi-clock me-1"></i> Sent on @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy · hh:mm tt")
                        </p>
                    </div>
                </div>

                <!-- Reply from Bakery -->
                @if (!string.IsNullOrEmpty(Model.Response))
                {
                    <div class="mb-3">
                        <div class="text-center mb-3">
                            <i class="bi bi-reply-all-fill display-3" style="color: var(--leaf-green);"></i>
                            <h5 class="mt-2">Gruer's Reply</h5>
                            <div class="honey-accent mx-auto" style="width: 40px;"></div>
                        </div>
                        <div class="response-card p-4 rounded-3" style="background: rgba(107, 140, 66, 0.1); border-left: 4px solid var(--leaf-green);">
                            <p style="white-space: pre-wrap;">@Model.Response</p>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-2">
                                <small class="text-muted">
                                    <i class="bi bi-reply me-1"></i> Replied on @Model.RespondedOnFormatted
                                </small>
                                @if (!string.IsNullOrEmpty(Model.RespondedByName))
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-person me-1"></i> — @Model.RespondedByName, from Gruer's team
                                    </small>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-hourglass-split display-4 text-muted"></i>
                        <p class="mt-3">Your letter is waiting to be read</p>
                        <p class="small text-muted">Gruer and the team will reply soon with warmth</p>
                    </div>
                }

                <hr class="stone-divider my-4">

                <div class="d-flex justify-content-center gap-2">
                    <a asp-controller="Profile" asp-action="Index" class="btn-glow">
                        <i class="bi bi-house-heart me-1"></i> Return to my corner
                    </a>
                    @if (string.IsNullOrEmpty(Model.Response))
                    {
                        <a asp-controller="ContactMessage" asp-action="Index" class="btn-warm">
                            <i class="bi bi-pencil me-1"></i> Write another letter
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .response-card {
        border-radius: 16px;
    }
</style>