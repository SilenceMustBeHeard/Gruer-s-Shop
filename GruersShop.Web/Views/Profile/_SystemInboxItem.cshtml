@using GruersShop.Data.Common.Enums
@using GruersShop.Web.ViewModels.Account.Messages;
@model SystemInboxMessageViewModel

<a asp-controller="Profile"
       asp-action="SystemMessageDetails"
       asp-route-id="@Model.Id"
       class="text-decoration-none">

    <div class="glass-list-item p-3 mb-3 message-card @(Model.IsRead ? "read" : "unread")">

        @* Date and status on top *@
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="d-flex align-items-center gap-2">
                <div class="status-dot @(Model.IsRead ? "bg-secondary" : "bg-warning")"></div>
                <small class="text-muted">
                    @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy · HH:mm")
                </small>

                @* Message Type Badge - Using your actual enum values *@
                @if (Model.Type == InboxMessageType.AdminToUser)
                {
                    <span class="badge bg-info ms-2">System</span>
                }
                else if (Model.Type == InboxMessageType.Notification)
                {
                    <span class="badge bg-primary ms-2">Design Sent</span>
                }
               
            </div>

            @if (!Model.IsRead)
            {
                <span class="unread-badge">New</span>
            }
        </div>

        @* Message Preview *@
        <p class="text-light mb-3 message-preview">
            @(Model.Description.Length > 100 ? Model.Description.Substring(0, 100) + "..." : Model.Description)
        </p>

        @* Sender info if available *@
        @if (!string.IsNullOrEmpty(Model.SenderName))
        {
            <div class="small text-muted mb-2">
                <i class="bi bi-person me-1"></i>From: @Model.SenderName
            </div>
        }

        @* Read Message button *@
        <div class="d-flex gap-2" onclick="event.stopPropagation()">
            <a asp-controller="Profile"
                   asp-action="SystemMessageDetails"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary-glass btn-sm w-100">
                <i class="bi bi-envelope-open me-1"></i>Read Message
            </a>
        </div>
    </div>
</a>