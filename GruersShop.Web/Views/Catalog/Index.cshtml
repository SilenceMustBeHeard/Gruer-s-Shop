@using GruersShop.Web.ViewModels.Bakery
@model CatalogIndexViewModel

@{
    ViewData["Title"] = "Our Bakery";
    var isGuest = !User.Identity?.IsAuthenticated ?? true;
}

<div class="container py-5">
    <!-- Hero Section -->
    <div class="hero-oven text-center mb-5">
        <i class="bi bi-shop display-1"></i>
        <h1 class="display-3 mt-2">Our Bakery</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="lead mt-3">Freshly baked goods made with love and the finest ingredients</p>
    </div>

    <!-- Category Filter -->
    @if (!isGuest)
    {
        <div class="mb-5">
            <div class="d-flex flex-wrap justify-content-center gap-2">

                <!-- ALL -->
                <a asp-controller="Catalog"
                       asp-action="Index"
                       asp-route-page="1"
                       class="filter-btn @(Model.SelectedCategoryId == null ? "active" : "")">
                    All Products
                </a>

                @foreach (var category in Model.Categories)
                {
                    <a asp-controller="Catalog"
                           asp-action="Index"
                           asp-route-page="1"
                           asp-route-categoryId="@category.Id"
                           class="filter-btn @(Model.SelectedCategoryId == category.Id ? "active" : "")">
                        <i class="@(category.IconClass ?? "bi bi-tag") me-1"></i>
                        @category.Name
                        <span class="count-badge">@category.ProductCount</span>
                    </a>
                }
            </div>
        </div>
    }

    <!-- Products Grid -->
    @if (!Model.Products.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-egg-fried display-1 text-muted"></i>
            <h3 class="mt-3">No products found</h3>
            <p class="text-muted">Check back soon for fresh baked goods!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="product-card h-100">
                        <div class="product-card-image">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name"
                                     style="width: 100%; height: 200px; object-fit: cover; border-radius: 12px 12px 0 0;" />
                            }
                            else
                            {
                                <i class="bi bi-cup-hot display-1 text-white-50"></i>
                            }
                        </div>

                        <div class="product-card-content">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="product-card-title mb-0">@product.Name</h3>
                                @if (product.AverageRating > 0)
                                {
                                    <small class="text-warm">
                                        <i class="bi bi-star-fill"></i> @product.AverageRating.ToString("0.0")
                                    </small>
                                }
                            </div>

                            <p class="text-muted small">
                                @(product.Description?.Length > 100
                                    ? product.Description.Substring(0, 100) + "..."
                                    : product.Description)
                            </p>

                            @if (isGuest)
                            {
                                <div class="mt-3 pt-2">
                                    <a asp-controller="Account"
                                           asp-action="Login"
                                           asp-route-returnUrl="@Context.Request.Path"
                                           class="btn-warm-sm w-100 text-center">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>
                                        Login to View Details & Price
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-warm fw-bold fs-5">
                                        @product.Price.ToString("C")
                                    </span>

                                    <a asp-controller="ProductDetails"
                                           asp-action="Index"
                                           asp-route-id="@product.Id"
                                           class="btn-glow-sm">
                                        <i class="bi bi-eye me-1"></i> View Details
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (!isGuest && Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">

                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link-warm"
                                   asp-controller="Catalog"
                                   asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link-warm"
                                   asp-controller="Catalog"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link-warm"
                                   asp-controller="Catalog"
                                   asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    }

                </ul>
            </nav>
        }

        <!-- Guest CTA -->
        @if (isGuest && Model.TotalProducts > 3)
        {
            <div class="text-center mt-5 p-4 warm-card">
                <i class="bi bi-lock-fill display-4 text-warm mb-2 d-block"></i>
                <h4>@(Model.TotalProducts - 3) More Products Await You!</h4>
                <p class="text-muted">
                    Create an account to see all products and prices.
                </p>

                <div class="d-flex justify-content-center gap-3 mt-3">
                    <a asp-controller="Account"
                           asp-action="Login"
                           asp-route-returnUrl="@Context.Request.Path"
                           class="btn-glow">
                        Login
                    </a>

                    <a asp-controller="Account"
                           asp-action="Register"
                           asp-route-returnUrl="@Context.Request.Path"
                           class="btn-warm">
                        Register
                    </a>
                </div>
            </div>
        }
    }
</div>