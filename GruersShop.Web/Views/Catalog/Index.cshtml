@using GruersShop.Web.ViewModels.Bakery
@model CatalogIndexViewModel

@{
    ViewData["Title"] = "Our Bakery";
}

<div class="container py-5">
    <!-- Hero Section -->
    <div class="hero-oven text-center mb-5">
        <i class="bi bi-shop display-1"></i>
        <h1 class="display-3 mt-2">Our Bakery</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="lead mt-3">Freshly baked goods made with love and the finest ingredients</p>
    </div>

    <!-- Category Filter -->
    <div class="mb-5">
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-action="Index" asp-route-page="1" asp-route-categoryId=""
                   class="filter-btn @(Model.SelectedCategoryId == null ? "active" : "")">
                All Products
            </a>
            @foreach (var category in Model.Categories)
            {
                <a asp-action="Index" asp-route-page="1" asp-route-categoryId="@category.Id"
                       class="filter-btn @(Model.SelectedCategoryId == category.Id ? "active" : "")">
                    <i class="@(category.IconClass ?? "bi bi-tag") me-1"></i>
                    @category.Name
                    <span class="count-badge">@category.ProductCount</span>
                </a>
            }
        </div>
    </div>

    <!-- Products Grid -->
    @if (!Model.Products.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-egg-fried display-1 text-muted"></i>
            <h3 class="mt-3">No products found</h3>
            <p class="text-muted">Check back soon for fresh baked goods!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4">
                    @await Html.PartialAsync("_ProductCard", product)
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-5">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link-warm" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                <i class="bi bi-chevron-left"></i> Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link-warm" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link-warm" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-categoryId="@Model.SelectedCategoryId">
                                Next <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

<style>
    .filter-btn {
        background: var(--stone-light);
        border: 1px solid var(--stone-medium);
        color: var(--wood-dark);
        padding: 0.5rem 1.2rem;
        border-radius: 40px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .filter-btn:hover {
        background: var(--stone-medium);
        color: var(--wood-very-dark);
    }
    
    .filter-btn.active {
        background: var(--wood-medium);
        color: white;
        border-color: var(--wood-medium);
    }
    
    .count-badge {
        background: rgba(0,0,0,0.1);
        border-radius: 20px;
        padding: 0.1rem 0.5rem;
        font-size: 0.7rem;
    }
    
    .page-link-warm {
        background: var(--warm-light);
        border: 1px solid var(--stone-medium);
        color: var(--wood-dark);
        padding: 0.5rem 1rem;
        text-decoration: none;
        border-radius: 8px;
        margin: 0 0.2rem;
        transition: all 0.3s ease;
    }
    
    .page-link-warm:hover {
        background: var(--stone-light);
    }
    
    .page-item.active .page-link-warm {
        background: var(--wood-medium);
        color: white;
        border-color: var(--wood-medium);
    }
    
    [data-bs-theme="dark"] .filter-btn,
    [data-bs-theme="dark"] .page-link-warm {
        background: #4a3020;
        border-color: #6b4a30;
        color: #e8d9cc;
    }
    
    [data-bs-theme="dark"] .filter-btn:hover,
    [data-bs-theme="dark"] .page-link-warm:hover {
        background: #5c3a1e;
    }
</style>