@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card glassmorphism-card text-center p-5 animate__animated animate__fadeInUp">
                
                @* Error image *@
                <div class="error-image-container mb-4 position-relative">
                    <img src="~/images/errors/404-error.png"
                         alt="404 Not Found"
                         class="img-fluid"
                         style="max-height: 220px;"
                         onerror="this.onerror=null; this.src='https://via.placeholder.com/300x220/2c3e50/ffffff?text=404+-+Not+Found'">
                        <div class="position-absolute top-0 start-50 translate-middle-x mt-2">
                            <span class="badge bg-dark bg-opacity-50 text-white px-3 py-2 rounded-pill">
                                <i class="bi bi-exclamation-triangle me-1"></i>404
                            </span>
                        </div>
                    </div>

                    <h1 class="display-1 fw-bold text-primary mb-0">404</h1>
                    <h2 class="h3 fw-bold text-muted mb-4">Page Not Found</h2>

                    <p class="text-muted mb-2">The page you're looking for doesn't exist or has been moved.</p>
                    <p class="text-muted mb-4">Let's get you back on track!</p>

                    <div class="search-box mb-4">
                        <form asp-controller="Home" asp-action="Search" method="get" class="d-flex gap-2">
                            <input type="text" name="query" class="form-control form-control-lg"
                                   placeholder="Search our website..." aria-label="Search">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-primary btn-lg px-4 hover-scale">
                            <i class="bi bi-house-door me-2"></i>Back to Home
                        </a>
                        <a asp-controller="Home"
                               asp-action="Sitemap"
                               class="btn btn-outline-primary btn-lg px-4 hover-scale">
                            <i class="bi bi-diagram-3 me-2"></i>Sitemap
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>