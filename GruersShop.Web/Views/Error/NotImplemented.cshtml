﻿@{
    ViewData["Title"] = "Under Construction - Gruers Bakery";
    string featureName = ViewBag.FeatureName ?? "This recipe";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="warm-card p-5 text-center bakery-error-card" id="errorCard">
                
                <!-- Animated construction bakery elements -->
                <div class="construction-area mb-4">
                    <div class="oven-baking">
                        <i class="bi bi-egg-fried display-1 text-warm"></i>
                        <div class="steam">
                            <i class="bi bi-cloud"></i>
                            <i class="bi bi-cloud"></i>
                            <i class="bi bi-cloud"></i>
                        </div>
                    </div>
                    <div class="tools">
                        <i class="bi bi-hammer tool-1"></i>
                        <i class="bi bi-wrench tool-2"></i>
                        <i class="bi bi-gear tool-3"></i>
                    </div>
                </div>

                <div class="error-badge mb-3">
                    <span class="stone-badge" style="background: var(--honey-gold); color: var(--wood-very-dark);">
                        <i class="bi bi-tools me-1"></i> 501 - Baking in Progress
                    </span>
                </div>

                <h1 class="display-4 fw-bold mb-3" style="color: var(--wood-dark);">
                    🚧 <span class="text-warm">Still in the Oven!</span>
                </h1>

                <p class="text-muted mb-2">@featureName is currently being perfected by our master bakers.</p>
                <p class="text-muted mb-4">We're kneading, proofing, and baking something amazing for you!</p>

                <div class="progress-container mb-4">
                    <div class="progress-label d-flex justify-content-between mb-1">
                        <small class="text-muted">Baking Progress</small>
                        <small class="text-warm" id="progressPercent">65%</small>
                    </div>
                    <div class="progress" style="height: 12px; border-radius: 20px; background: var(--stone-light);">
                        <div class="progress-bar" id="bakingProgress" 
                             role="progressbar" style="width: 65%; background: var(--honey-gold); border-radius: 20px; transition: width 0.5s ease;">
                        </div>
                    </div>
                    <div class="baking-status mt-2">
                        <small class="text-muted" id="bakingStatus">🍪 Kneading dough...</small>
                    </div>
                </div>

                <div class="estimated-time warm-card p-3 mb-4">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-clock-history text-warm"></i>
                        <span class="small">Estimated baking time: <strong id="estimatedTime">~5 minutes</strong></span>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn-glow">
                        <i class="bi bi-house-heart me-2"></i> Visit Bakery
                    </a>
                    <button onclick="history.back()" class="btn-warm">
                        <i class="bi bi-arrow-return-left me-2"></i> Go Back
                    </button>
                </div>

                <div class="mt-4">
                    <small class="text-muted">
                        <i class="bi bi-heart-fill text-danger me-1" style="font-size: 0.7rem;"></i>
                        Freshly baked at Gruers Bakery
                        <i class="bi bi-heart-fill text-danger ms-1" style="font-size: 0.7rem;"></i>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('🔧 Bakery Error Page - Under Construction');
        
        let progress = 65;
        const progressBar = document.getElementById('bakingProgress');
        const progressPercent = document.getElementById('progressPercent');
        const bakingStatus = document.getElementById('bakingStatus');
        const estimatedTime = document.getElementById('estimatedTime');
        
        const statusMessages = [
            '🍪 Kneading dough...',
            '🥐 Shaping croissants...',
            '🍰 Preparing frosting...',
            '🎂 Decorating cake...',
            '🔥 Preheating oven...',
            '🍞 Baking fresh bread...',
            '✨ Adding magic sprinkles...'
        ];
        
        let messageIndex = 0;
        
        // Simulate baking progress
        const progressInterval = setInterval(() => {
            if (progress < 100) {
                progress += Math.random() * 3;
                if (progress > 100) progress = 100;
                
                progressBar.style.width = progress + '%';
                progressPercent.textContent = Math.floor(progress) + '%';
                
                // Update status message
                if (Math.random() > 0.7) {
                    bakingStatus.textContent = statusMessages[messageIndex % statusMessages.length];
                    messageIndex++;
                }
                
                // Update estimated time based on progress
                const remainingMinutes = Math.ceil((100 - progress) / 10);
                if (remainingMinutes > 0) {
                    estimatedTime.textContent = `~${remainingMinutes} minute${remainingMinutes > 1 ? 's' : ''}`;
                } else {
                    estimatedTime.textContent = 'Almost ready!';
                }
            } else {
                clearInterval(progressInterval);
                bakingStatus.innerHTML = '🎉 Ready to serve! Coming soon... 🎉';
                estimatedTime.textContent = 'Any moment now!';
            }
        }, 800);
        
        // Animate on page load
        const card = document.querySelector('.bakery-error-card');
        card.style.animation = 'gentleFloat 0.6s ease-out';
    });
</script>