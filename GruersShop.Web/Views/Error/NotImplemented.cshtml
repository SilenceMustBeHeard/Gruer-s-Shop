@{
    ViewData["Title"] = "Not Implemented";
    string featureName = ViewBag.FeatureName ?? "This feature";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card glassmorphism-card text-center p-5 animate__animated animate__fadeInUp">
                
                @* Error image *@
                <div class="error-image-container mb-4">
                    <img src="~/images/errors/under-construction.png"
                         alt="Under Construction"
                         class="img-fluid floating-animation"
                         style="max-height: 220px;"
                         onerror="this.onerror=null; this.src='https://via.placeholder.com/300x220/2c3e50/ffffff?text=🚧+Under+Construction'">
                    </div>

                    <div class="error-badge bg-warning bg-opacity-10 text-warning px-3 py-1 rounded-pill d-inline-block mx-auto mb-3">
                        <small>⚠️ ERROR @(ViewBag.ErrorCode ?? 501)</small>
                    </div>

                    <h1 class="display-5 fw-bold text-warning mb-3">
                        <span class="d-block">🚧 Under Construction</span>
                    </h1>

                    <p class="text-muted mb-2">Oops! @featureName is still in development.</p>
                    <p class="text-muted mb-4">We're working hard to bring you something amazing!</p>

                    <div class="progress mb-4" style="height: 10px;">
                        <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated"
                             role="progressbar" style="width: 65%;" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-warning btn-lg px-4 hover-scale">
                            <i class="bi bi-house-door me-2"></i>Back to Home
                        </a>
                        <button onclick="history.back()"
                                class="btn btn-outline-secondary btn-lg px-4 hover-scale">
                            <i class="bi bi-arrow-left me-2"></i>Go Back
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>