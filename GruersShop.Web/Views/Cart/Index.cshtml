@using GruersShop.Web.ViewModels.Cart
@model CartViewModel

@{
    ViewData["Title"] = "My Cart";
}

<div class="container py-5">
    <div class="hero-oven text-center mb-5">
        <i class="bi bi-cart4 display-1"></i>
        <h1 class="display-3 mt-2">My Cart</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="lead mt-3">Review your order before checkout</p>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Your cart is empty</h3>
            <p class="text-muted">Looks like you haven't added any goodies yet.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn-glow mt-3">
                <i class="bi bi-shop me-2"></i> Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="warm-card p-4">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr class="text-muted">
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr id="cart-item-@item.ProductId">
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                                <div>
                                                    <h6 class="fw-bold mb-0">@item.ProductName</h6>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@item.Price.ToString("C")</td>
                                        <td style="width: 120px;">
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="number" name="quantity" value="@item.Quantity"
                                                       class="form-control form-control-sm text-center"
                                                       style="width: 70px;" min="1" max="99"
                                                       onchange="this.form.submit()" />
                                                <i class="bi bi-arrow-repeat text-muted"></i>
                                            </form>
                                        </td>
                                        <td class="fw-bold">@item.Subtotal.ToString("C")</td>
                                        <td>
                                            <form asp-action="RemoveFromCart" method="post" onsubmit="return confirm('Remove this item from cart?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-sm btn-link text-danger">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-end mt-3">
                        <a asp-controller="Catalog" asp-action="Index" class="btn-warm-sm">
                            <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                        </a>
                    </div>
                </div>
            </div>

            <!-- Cart Summary -->
            <div class="col-lg-4">
                <div class="warm-card p-4">
                    <h4 class="fw-bold mb-3">Order Summary</h4>
                    <hr class="stone-divider">
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <span>@Model.TotalAmount.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping:</span>
                        <span>Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Tax (10%):</span>
                        <span>@((Model.TotalAmount * 0.1m).ToString("C"))</span>
                    </div>
                    <hr class="stone-divider">
                    <div class="d-flex justify-content-between mb-4">
                        <strong>Total:</strong>
                        <strong class="text-warm">@((Model.TotalAmount * 1.1m).ToString("C"))</strong>
                    </div>

                    <a asp-action="Checkout" class="btn-glow w-100 py-2">
                        <i class="bi bi-credit-card me-2"></i> Proceed to Checkout
                    </a>
                </div>
            </div>
        </div>
    }
</div>

