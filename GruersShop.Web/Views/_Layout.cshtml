<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Furniture &amp; Garden Design</title>
    @* links for Bootstrap *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
          @* links for site theme settings*@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>



@*To do : Somewhere along the way - integrate music player*@
<body>

    <header>
        @* navbar style px,py represent how much padding to apply*@
        <nav class="navbar navbar-expand-lg glass navbar-dark rounded-9 px-1 py-1">

            <div class="container-fluid">

              @* Left/Logo *@
                <div class="d-flex align-items-center gap-3">
                    <a class="navbar-brand logo-wrapper"
                       asp-controller="Home"
                       asp-action="Index">

                    
                       @*site name logo*@

                        <svg class="fgd-logo" width="300" height="40" viewBox="0 0 320 48">
                            <text x="0" y="34" class="logo-text">
                                Furniture &amp; Garden Design
                            </text>
                        </svg>

                    </a>
                    @*button About*@
                    <a class="btn btn-outline-glass btn-sm" asp-controller="Home" asp-action="About">About</a>
                    @*button Privacy*@
                    <a class="btn btn-outline-glass btn-sm" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>

            
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                  @*  Center/Navbar *@
                    <div class="mx-auto d-flex gap-4">
                        @await Component.InvokeAsync("Navbar")
                    </div>

                  

                  @* Right/Account menu *@
                    <div class="d-flex gap-3">
                        <button id="themeToggle" class="btn btn-outline-glass btn-sm">🌙</button>

                        <div class="dropdown">
                            <button class="btn btn-primary-glass dropdown-toggle" data-bs-toggle="dropdown">
                                Account
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @await Component.InvokeAsync("AccountMenu")
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </nav>


  @*    Temp Data alerts *@
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div id="tempSuccess" class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div id="tempError" class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </header>



    @* Scene *@
    <div class="scene-wrapper">

          @*image*@
        <div class="scene-bg"></div>

     @*light mode layers*@ 
        <div class="light-path"></div>
        <div class="light-vignette"></div>

        @* Dark mode layers *@
        <div class="dark-path"></div>
        <div class="dark-vignette"></div>

        @* Actual page content *@
        <div class="container scene-content">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

    </div>

    @* Footer *@
    <footer class="glass-footer text-center text-muted border-top">

        <div class="container">&copy; 2025 - Furniture &amp; Garden Design</div>
    </footer>

    @* Scripts  for functionality *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* To do : Implement reference image preview functionality *@
 @*    <script src="~/js/referencePreview.js" asp-append-version="true"></script> *@



    @*script for reference image preview*@




    @*scripts for temporary alerts*@

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        setTimeout(() => {
            const success = document.getElementById("tempSuccess");
            const error = document.getElementById("tempError");

            if (success) success.style.display = "none";
            if (error) error.style.display = "none";
        }, 1500); // 1.5 seconds
    </script>
   



</body>
</html>
