@using GruersShop.Web.ViewModels.Account.Profile
@model ProfileViewModel

@{
    ViewData["Title"] = "Admin Profile";
}

<div class="container py-5">
    <div class="hero-oven text-center mb-5">
        <i class="bi bi-person-badge display-1"></i>
        <h1 class="display-3 mt-2">Admin Profile</h1>
        <div class="honey-accent mx-auto"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="warm-card text-center p-4">
                <div class="mb-3">
                    <div class="profile-avatar mx-auto">
                        <i class="bi bi-shield-lock display-1 text-warm"></i>
                    </div>
                </div>
                <h2 class="fw-bold">@Model.FirstName @Model.LastName</h2>
                <div class="honey-accent mx-auto" style="width: 40px;"></div>
                
                <div class="mt-4 text-start">
                    <div class="info-row mb-3">
                        <i class="bi bi-envelope me-2 text-warm"></i>
                        <div>
                            <small class="text-muted d-block">Email</small>
                            <span>@Model.Email</span>
                        </div>
                    </div>
                    <div class="info-row mb-3">
                        <i class="bi bi-geo-alt me-2 text-warm"></i>
                        <div>
                            <small class="text-muted d-block">Address</small>
                            <span>@(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)</span>
                        </div>
                    </div>
                </div>

                <hr class="stone-divider my-3">

                <div class="d-flex gap-2 justify-content-center">
                    <a asp-area="Admin" asp-controller="AdminProfile" asp-action="AdminInbox" class="btn-warm-sm">
                        <i class="bi bi-envelope me-1"></i> Contact Messages
                    </a>
                    <a asp-area="Admin" asp-controller="AdminProfile" asp-action="SystemInbox" class="btn-warm-sm">
                        <i class="bi bi-megaphone me-1"></i> System Messages
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>