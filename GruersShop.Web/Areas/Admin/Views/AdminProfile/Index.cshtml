@using GruersShop.Web.ViewModels.Account.Profile
@model ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">

    <!-- HERO -->
    <div class="hero-oven text-center mb-5">
        <div class="profile-avatar mx-auto mb-3">
            <i class="bi bi-shield-lock display-1 text-warm"></i>
        </div>

        <h1 class="display-4 mt-2">@Model.FirstName @Model.LastName</h1>

        <span class="badge bg-warning text-dark mt-2">
            ADMIN ROLE
        </span>

        <div class="honey-accent mx-auto mt-3"></div>
    </div>

    <!-- CARD -->
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="warm-card p-4 position-relative overflow-hidden">

                <!-- subtle glow effect -->
                <div class="profile-glow"></div>

                <!-- EMAIL -->
                <div class="d-flex align-items-start gap-3 mb-4">
                    <i class="bi bi-envelope-fill text-warm fs-5"></i>
                    <div>
                        <small class="text-muted d-block">Email</small>
                        <span class="fw-semibold">@Model.Email</span>
                    </div>
                </div>

                <!-- ADDRESS -->
                <div class="d-flex align-items-start gap-3 mb-4">
                    <i class="bi bi-geo-alt-fill text-warm fs-5"></i>
                    <div>
                        <small class="text-muted d-block">Address</small>
                        <span class="fw-semibold">
                            @(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)
                        </span>
                    </div>
                </div>

                <hr class="stone-divider my-4">

                <!-- ACTIONS -->
                <div class="d-flex flex-column flex-md-row gap-2 justify-content-center">

                    <a asp-area="Admin"
                           asp-controller="AdminProfile"
                           asp-action="AdminInbox"
                           class="btn-warm-sm flex-fill text-center">
                        <i class="bi bi-envelope me-1"></i>
                        Messages
                    </a>

                    <a asp-area="Admin"
                           asp-controller="AdminProfile"
                           asp-action="SystemInbox"
                           class="btn-glow-sm flex-fill text-center">
                        <i class="bi bi-megaphone me-1"></i>
                        System
                    </a>

                </div>

            </div>
        </div>
    </div>
</div>