@using GruersShop.Web.ViewModels.Account.Profile
@model ProfileViewModel

@{
    ViewData["Title"] = "Admin Profile";
}

<div class="container py-5">

    <!-- Welcome Banner with animated glow -->
    <div class="hero-oven text-center mb-5" id="heroBanner">
        <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
            <i class="bi bi-shield-lock display-4 icon-pulse"></i>
            <i class="bi bi-heart-fill text-warm icon-float"></i>
            <i class="bi bi-egg-fried display-4 icon-rotate"></i>
        </div>
        <h1 class="display-4">Welcome back, <span class="text-glow">@Model.FirstName</span>! 🥐</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="mt-3">Your command center as Admin</p>
    </div>

    <div class="row g-4">
        <!-- Admin Info Card -->
        <div class="col-lg-4">
            <div class="warm-card text-center profile-card">
                <div class="mb-3">
                    <div class="profile-avatar mx-auto">
                        <i class="bi bi-shield-lock display-1 text-warm"></i>
                    </div>
                </div>
                <h3 class="fw-bold">@Model.FirstName @Model.LastName</h3>
                <div class="honey-accent mx-auto" style="width: 40px;"></div>
                <span class="badge bg-warning text-dark mt-2 admin-badge">ADMINISTRATOR</span>
                
                <div class="mt-4 text-start">
                    <div class="info-item mb-2">
                        <small class="text-muted">Email</small>
                        <p class="mb-0"><i class="bi bi-envelope me-2 text-warm"></i> @Model.Email</p>
                    </div>
                    <div class="info-item mb-2">
                        <small class="text-muted">Location</small>
                        <p class="mb-0"><i class="bi bi-geo-alt me-2 text-warm"></i> @(string.IsNullOrEmpty(Model.Address) ? "Not shared yet" : Model.Address)</p>
                    </div>
                    <div class="info-item">
                        <small class="text-muted">Role</small>
                        <p class="mb-0"><i class="bi bi-shield-lock me-2 text-warm"></i> Full Access • God Mode</p>
                    </div>
                </div>

                <hr class="stone-divider my-3">

                <a asp-area="Admin" asp-controller="Account" asp-action="Logout" class="btn-warm-sm w-100 logout-btn">
                    <i class="bi bi-box-arrow-right me-1"></i> Sign out
                </a>
            </div>
        </div>

        <!-- Messages Section -->
        <div class="col-lg-8">
            <div class="warm-card messages-card">
                <div class="d-flex gap-2 border-bottom pb-3 mb-3">
                    <button class="tab-btn active" id="systemTabBtn">
                        <i class="bi bi-megaphone me-1"></i> System Messages
                        @if (Model.SystemInbox?.Count(x => !x.IsRead) > 0)
                        {
                            <span class="honey-badge ms-1 pulse-badge">@Model.SystemInbox.Count(x => !x.IsRead)</span>
                        }
                    </button>
                    <button class="tab-btn" id="contactTabBtn">
                        <i class="bi bi-chat-heart me-1"></i> Contact Messages
                        @if (Model.ContactMessages?.Count(x => !x.IsReadByAdmin) > 0)
                        {
                            <span class="honey-badge ms-1 pulse-badge">@Model.ContactMessages.Count(x => !x.IsReadByAdmin)</span>
                        }
                    </button>
                </div>

                <!-- System Messages Panel -->
                <div id="systemMessagesPanel" class="tab-panel active">
                    @if (Model.SystemInbox == null || !Model.SystemInbox.Any())
                    {
                        <div class="text-center py-5 empty-state">
                            <i class="bi bi-envelope-open display-4 text-muted"></i>
                            <p class="mt-3">No system messages</p>
                            <p class="small text-muted">System announcements will appear here</p>
                        </div>
                    }
                    else
                    {
                        <div class="letters-stack">
                            @foreach (var message in Model.SystemInbox.OrderByDescending(x => x.CreatedOn))
                            {
                                <div class="letter-item message-item" data-id="@message.Id">
                                    <a asp-area="Admin" asp-controller="AdminProfile" asp-action="SystemMessageDetails" asp-route-id="@message.Id" class="letter-link">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="d-flex gap-2 align-items-center">
                                                <i class="bi bi-megaphone text-warm"></i>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@message.Title</h6>
                                                    <small class="text-muted">@message.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</small>
                                                </div>
                                            </div>
                                            @if (!message.IsRead)
                                            {
                                                <span class="honey-badge">New</span>
                                            }
                                        </div>
                                        <p class="mt-2 mb-0 small text-muted message-preview">@(message.Description.Length > 100 ? message.Description.Substring(0, 100) + "..." : message.Description)</p>
                                        <div class="mt-2">
                                            <span class="read-more-link">Read message <i class="bi bi-arrow-right"></i></span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Contact Messages Panel -->
                <div id="contactMessagesPanel" class="tab-panel">
                    @if (Model.ContactMessages == null || !Model.ContactMessages.Any())
                    {
                        <div class="text-center py-5 empty-state">
                            <i class="bi bi-envelope-paper display-4 text-muted"></i>
                            <p class="mt-3">No contact messages</p>
                            <p class="small text-muted">Customer messages will appear here</p>
                        </div>
                    }
                    else
                    {
                        <div class="letters-stack">
                            @foreach (var message in Model.ContactMessages.OrderByDescending(x => x.CreatedOn))
                            {
                                <div class="letter-item message-item" data-id="@message.Id">
                                    <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Details" asp-route-id="@message.Id" class="letter-link">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="d-flex gap-2 align-items-center">
                                                <i class="bi bi-chat-heart text-warm"></i>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@message.Subject</h6>
                                                    <small class="text-muted">@message.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</small>
                                                </div>
                                            </div>
                                            @if (!message.IsReadByAdmin)
                                            {
                                                <span class="honey-badge">New</span>
                                            }
                                        </div>
                                        <p class="mt-2 mb-2 small text-muted message-preview">@(message.Message.Length > 100 ? message.Message.Substring(0, 100) + "..." : message.Message)</p>
                                        <div class="mt-2">
                                            <span class="read-more-link">View & respond <i class="bi bi-arrow-right"></i></span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    document.addEventListener('DOMContentLoaded', function() {
        const systemTab = document.getElementById('systemTabBtn');
        const contactTab = document.getElementById('contactTabBtn');
        const systemPanel = document.getElementById('systemMessagesPanel');
        const contactPanel = document.getElementById('contactMessagesPanel');
        
        if (systemTab && contactTab) {
            function setActiveTab(active) {
                if (active === 'system') {
                    systemTab.classList.add('active');
                    contactTab.classList.remove('active');
                    systemPanel.classList.add('active');
                    contactPanel.classList.remove('active');
                } else {
                    contactTab.classList.add('active');
                    systemTab.classList.remove('active');
                    contactPanel.classList.add('active');
                    systemPanel.classList.remove('active');
                }
            }
            
            systemTab.onclick = () => setActiveTab('system');
            contactTab.onclick = () => setActiveTab('contact');
        }
        
        // Add hover sound effect (optional - just for fun)
        const items = document.querySelectorAll('.message-item');
        items.forEach(item => {
            item.addEventListener('mouseenter', () => {
                // Visual feedback
                item.style.transition = 'all 0.2s ease';
            });
        });
        
        // Log welcome message
        console.log('🔥 Admin Profile loaded - Welcome Commander!');
    });
</script>