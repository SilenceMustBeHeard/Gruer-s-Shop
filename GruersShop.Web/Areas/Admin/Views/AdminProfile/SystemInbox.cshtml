@using GruersShop.Data.Common.Enums
@using GruersShop.Web.ViewModels.Account.Messages
@model IEnumerable<SystemInboxMessageViewModel>

@{
    ViewData["Title"] = "System Messages";
}

<div class="container py-5">
    <div class="warm-card p-4">
        <div class="text-center mb-4">
            <i class="bi bi-megaphone display-1 text-warm"></i>
            <h1 class="display-4 mt-2">System Messages</h1>
            <div class="honey-accent mx-auto"></div>
            <p class="text-muted">Important announcements and notifications</p>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-envelope-open display-4 text-muted"></i>
                <p class="mt-3">No system messages</p>
            </div>
        }
        else
        {
            <div class="letters-stack">
                @foreach (var message in Model.OrderByDescending(m => m.CreatedOn))
                {
                    <div class="letter-item mb-3">
                        <a asp-area="Admin" asp-controller="AdminProfile" asp-action="SystemMessageDetails" asp-route-id="@message.Id" class="letter-link">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex gap-2 align-items-center">
                                    <i class="bi bi-megaphone text-warm"></i>
                                    <div>
                                        <h6 class="fw-bold mb-0">@message.Title</h6>
                                        <small class="text-muted">@message.CreatedOn.ToLocalTime().ToString("dd MMM yyyy · HH:mm")</small>
                                    </div>
                                </div>
                                @if (!message.IsRead)
                                {
                                    <span class="honey-badge">New</span>
                                }
                            </div>
                            <p class="mt-2 mb-0 small text-muted">@(message.Description.Length > 150 ? message.Description.Substring(0, 150) + "..." : message.Description)</p>
                            <div class="mt-2">
                                <span class="read-more-link">Read Message <i class="bi bi-arrow-right"></i></span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</div>