@using GruersShop.Web.ViewModels.Admin.Products
@model IEnumerable<ProductViewModelList>

@{
    ViewData["Title"] = "Product Management - Gruers Bakery";
}

<div class="container py-5">
    <div class="warm-card p-4" data-aos="fade-up">
        
        <!-- Header with Bakery Magic -->
        <div class="text-center mb-4">
            <div class="product-header">
                <div class="header-icon-wrapper">
                    <i class="bi bi-cake2 display-1 text-warm"></i>
                    <div class="flour-dust">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                </div>
                <h1 class="display-4 mt-2 fw-bold">Our <span class="text-warm">Bakery Goods</span></h1>
                <div class="honey-accent mx-auto"></div>
                <p class="text-muted">Manage your delicious products with love</p>
                <div class="product-stats mt-2 d-flex gap-3 justify-content-center flex-wrap">
                    <span class="honey-badge d-inline-flex align-items-center gap-2 px-3 py-2">
                        <i class="bi bi-cake2 fs-6"></i>
                        <span class="fw-semibold">Total Products:</span>
                        <strong class="text-glow fs-5">@Model.Count()</strong>
                    </span>
                    <span class="honey-badge d-inline-flex align-items-center gap-2 px-3 py-2">
                        <i class="bi bi-check-circle-fill fs-6"></i>
                        <span class="fw-semibold">Available:</span>
                        <strong class="text-glow fs-5">@Model.Count(p => p.IsAvailable && !p.IsDeleted)</strong>
                    </span>
                </div>
            </div>
        </div>

        <!-- Back Button -->
        <div class="mb-4 d-flex justify-content-between align-items-center">
            <a asp-area="Admin" asp-controller="AdminDashboard" asp-action="Index" class="btn-warm-sm back-btn">
                <i class="bi bi-arrow-left me-1"></i> Back to Bakery
            </a>
            <a asp-area="Admin" asp-controller="ProductManagement" asp-action="Create" class="btn-glow-sm">
                <i class="bi bi-plus-circle me-1"></i> Add New Product
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 empty-state">
                <i class="bi bi-cake2 display-4 text-muted"></i>
                <p class="mt-3">No products yet.</p>
                <p class="small text-muted">Create your first delicious product to start selling!</p>
                <a asp-area="Admin" asp-controller="ProductManagement" asp-action="Create" class="btn-glow mt-3">
                    <i class="bi bi-plus-circle me-2"></i> Create First Product
                </a>
            </div>
        }
        else
        {
            <!-- Products Grid -->
            <div class="row g-4" id="productsGrid">
                @foreach (var product in Model.OrderByDescending(p => p.CreatedOn))
                {
                    var isActive = product.IsAvailable && !product.IsDeleted;
                    <div class="col-lg-4 col-md-6" data-aos="fade-up">
                        <div class="product-card warm-card h-100 @(product.IsDeleted ? "deleted-product" : "") @(product.IsAvailable ? "available-product" : "unavailable-product")">
                            
                            @if (product.IsDeleted)
                            {
                                <div class="archived-ribbon">
                                    <i class="bi bi-archive me-1"></i> ARCHIVED
                                </div>
                            }
                            else if (!product.IsAvailable)
                            {
                                <div class="unavailable-ribbon">
                                    <i class="bi bi-eye-slash me-1"></i> UNAVAILABLE
                                </div>
                            }

                            <!-- Product Image -->
                            <div class="product-image-wrapper">
                                <img src="@product.ImageUrl" alt="@product.Name" class="product-image"
                                     onerror="this.src='https://placehold.co/400x300/2c3e50/ffffff?text=No+Image'">
                                <div class="product-status-badge @(isActive ? "status-available" : "status-unavailable")">
                                    @(isActive ? "Fresh" : "Sold Out")
                                </div>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h5 class="fw-bold product-name">@product.Name</h5>
                                <p class="small text-muted category-name">
                                    <i class="bi bi-bookmark-heart me-1 text-warm"></i> @product.CategoryName
                                </p>
                                
                                <div class="product-price mt-2">
                                    <span class="price-amount">@product.Price.ToString("C")</span>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="stock-badge ms-2">🍪 @product.StockQuantity in stock</span>
                                    }
                                    else
                                    {
                                        <span class="stock-badge out-of-stock ms-2">❌ Out of stock</span>
                                    }
                                </div>

                                <div class="product-meta mt-2">
                                    <small class="text-muted">
                                        <i class="bi bi-calendar me-1"></i> Added: @product.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")
                                    </small>
                                </div>

                                <div class="d-flex gap-2 mt-3">
                                    <!-- Edit Button -->
                                    <a asp-area="Admin"
                                           asp-controller="ProductManagement"
                                           asp-action="Edit"
                                           asp-route-id="@product.Id"
                                           class="action-icon-btn edit-btn"
                                           title="Edit Product">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    <!-- Details Button -->
                                    <a asp-area="Admin"
                                           asp-controller="ProductManagement"
                                           asp-action="Details"
                                           asp-route-id="@product.Id"
                                           class="action-icon-btn details-btn"
                                           title="View Details">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <!-- Toggle Availability Button -->
                                    <form asp-area="Admin"
                                          asp-controller="ProductManagement"
                                          asp-action="ToggleActive"
                                          asp-route-id="@product.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirmToggle('@product.Name', '@(product.IsAvailable ? "hide" : "show")')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="action-icon-btn @(product.IsAvailable ? "hide-btn" : "show-btn")"
                                                title="@(product.IsAvailable ? "Make Unavailable" : "Make Available")">
                                            <i class="bi @(product.IsAvailable ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
    }
    
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
    
    .product-image-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
        background: var(--stone-light);
    }
    
    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }
    
    .product-card:hover .product-image {
        transform: scale(1.05);
    }
    
    .product-status-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    
    .status-available {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
    }
    
    .status-unavailable {
        background: #6c757d;
        color: white;
    }
    
    .archived-ribbon, .unavailable-ribbon {
        position: absolute;
        top: 20px;
        left: -30px;
        background: #dc3545;
        color: white;
        padding: 5px 30px;
        font-size: 0.7rem;
        font-weight: bold;
        transform: rotate(-45deg);
        z-index: 10;
    }
    
    .unavailable-ribbon {
        background: #fd7e14;
    }
    
    .product-name {
        font-size: 1.1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .price-amount {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--honey-gold);
    }
    
    .stock-badge {
        font-size: 0.7rem;
        padding: 2px 8px;
        background: rgba(40, 167, 69, 0.1);
        border-radius: 20px;
        color: #28a745;
    }
    
    .out-of-stock {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
    }
    
    .deleted-product {
        opacity: 0.7;
    }
    
    .action-icon-btn {
        background: transparent;
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }
    
    .edit-btn {
        color: var(--honey-gold);
        background: rgba(245, 197, 66, 0.1);
    }
    
        .edit-btn:hover {
            background: var(--honey-gold);
            color: var(--wood-very-dark);
            transform: scale(1.1);
        }
    
    .details-btn {
        color: #17a2b8;
        background: rgba(23, 162, 184, 0.1);
    }
    
        .details-btn:hover {
            background: #17a2b8;
            color: white;
            transform: scale(1.1);
        }
    
    .hide-btn {
        color: #fd7e14;
        background: rgba(253, 126, 20, 0.1);
    }
    
        .hide-btn:hover {
            background: #fd7e14;
            color: white;
            transform: scale(1.1);
        }
    
    .show-btn {
        color: #28a745;
        background: rgba(40, 167, 69, 0.1);
    }
    
        .show-btn:hover {
            background: #28a745;
            color: white;
            transform: scale(1.1);
        }
</style>

@section Scripts {
    <script>
        function confirmToggle(productName, action) {
            const isHide = action === 'hide';
            const message = isHide
                ? `Are you sure you want to hide "${productName}"? It won't appear in the public catalog.`
                : `Are you sure you want to show "${productName}"? It will appear in the public catalog.`;
            
            return confirm(message);
        }
        
        // Check for TempData messages
        document.addEventListener('DOMContentLoaded', function() {
            const successMessage = '@TempData["Success"]';
            const errorMessage = '@TempData["Error"]';
            
            if (successMessage && successMessage !== '') {
                showToast(successMessage, 'success');
            }
            
            if (errorMessage && errorMessage !== '') {
                showToast(errorMessage, 'error');
            }
        });
        
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `user-toast ${type}`;
            toast.innerHTML = `
                <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill'}"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }, 100);
        }
        
        console.log('🍰 Product Management Loaded!');
    </script>
}