@{
    ViewData["Title"] = "Check Your Email";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="warm-card p-4 p-md-5 text-center">
                <i class="bi bi-envelope-paper display-1 text-warm"></i>
                <h1 class="display-5 mt-2">Check Your Email</h1>
                <div class="honey-accent mx-auto"></div>
                <p class="mt-3">If an account exists with that email, you will receive a password reset link shortly.</p>
                <a asp-action="Login" class="btn-glow mt-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Return to Login
                </a>
            </div>
        </div>
    </div>
</div>