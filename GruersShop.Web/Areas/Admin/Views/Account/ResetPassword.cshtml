@model GruersShop.Web.ViewModels.Account.Profile.ResetPasswordViewModel
@{
    ViewData["Title"] = "Admin - Reset Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="warm-card p-4 p-md-5 text-center">
                <i class="bi bi-shield-lock display-1 text-warm"></i>
                <h1 class="display-5 mt-2">Reset Password</h1>
                <div class="honey-accent mx-auto"></div>
                <p class="text-muted mt-3">Create a new password for your admin account.</p>

                <form asp-action="ResetPassword" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold text-start d-block">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text stone-input-prepend">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control warm-input" placeholder="New password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold text-start d-block">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text stone-input-prepend">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control warm-input" placeholder="Confirm new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn-glow w-100 py-2 mb-3">
                        <i class="bi bi-check-circle me-2"></i> Reset Password
                    </button>

                    <a asp-action="Login" class="btn-warm w-100 py-2">
                        <i class="bi bi-arrow-left me-2"></i> Back to Login
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}