@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">

    <!-- 🔥 HERO -->
    <div class="hero-oven text-center mb-5" data-aos="fade-down">
        <i class="bi bi-shield-lock display-1 text-warm"></i>
        <h1 class="display-3 mt-2">The Oven Control</h1>
        <div class="honey-accent mx-auto"></div>
        <p class="lead mt-3 text-muted">
            Manage the bakery. Shape the experience. Keep the fire alive.
        </p>
    </div>

    <!-- 🔥 CARDS -->
    <div class="warm-card p-4">
        <div class="row g-4">

            <!-- USERS -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-people display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Guests</h5>
                        <p class="small text-muted">Manage users & roles</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="UserManagement"
                           asp-action="Index"
                           class="btn-warm-sm mt-3 card-btn">
                        Rule <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

            <!-- ORDERS -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-receipt display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Orders</h5>
                        <p class="small text-muted">Track & process requests</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="Error"
                           asp-action="NotImplemented"
                           class="btn-warm-sm mt-3 card-btn">
                        Track <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <!-- PRODUCTS -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-cake2 display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Bakery Goods</h5>
                        <p class="small text-muted">Manage your delicious products</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="ProductManagement"
                           asp-action="EditList"
                           class="btn-warm-sm mt-3 card-btn">
                        Bake <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <!-- CATEGORIES -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-bookmarks-fill display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Recipe Books</h5>
                        <p class="small text-muted">Organize your bakery collections</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="CategoryManagement"
                           asp-action="EditList"
                           class="btn-warm-sm mt-3 card-btn">
                        Categorize <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

            <!-- MESSAGES -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-envelope-paper display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Letters</h5>
                        <p class="small text-muted">Customer messages</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="AdminProfile"
                           asp-action="AdminInbox"
                           class="btn-warm-sm mt-3 card-btn">
                        Read <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

            <!-- REVIEWS -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-star display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Voices</h5>
                        <p class="small text-muted">Customer reviews</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="ReviewManagement"
                           asp-action="EditList"
                           class="btn-warm-sm mt-3 card-btn">
                        Hear <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

            <!-- SYSTEM -->
            <div class="col-lg-3 col-md-6">
                <div class="dashboard-card warm-card h-100 text-center p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="card-icon">
                            <i class="bi bi-gear display-4 text-warm"></i>
                        </div>
                        <h5 class="fw-bold mt-3">The Machine</h5>
                        <p class="small text-muted">System controls</p>
                    </div>
                    <a asp-area="Admin"
                           asp-controller="Error"
                           asp-action="NotImplemented"
                           class="btn-warm-sm mt-3 card-btn">
                        Tune <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

        </div>
    </div>

    <!-- 🔥 QUOTE -->
    <div class="text-center mt-5">
        <div class="honey-accent mx-auto mb-3"></div>
        <p class="fst-italic text-muted">
            “A good bakery is not built on bread alone… but on care, craft, and control.”
        </p>
        <small class="text-muted">— Gruer</small>
    </div>

</div>

<script>
    // add ripple effect on click for cards
    document.querySelectorAll('.dashboard-card').forEach(card => {
        card.addEventListener('click', function(e) {

            // if  click is on a link, don't create ripple
            if (e.target.closest('a')) return;
            
            const ripple = document.createElement('div');
            ripple.className = 'ripple-effect';
            ripple.style.left = e.clientX - card.getBoundingClientRect().left + 'px';
            ripple.style.top = e.clientY - card.getBoundingClientRect().top + 'px';
            card.appendChild(ripple);
            
            setTimeout(() => ripple.remove(), 500);
        });
    });

    // load animation for cards
    document.querySelectorAll('.dashboard-card').forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(30px)';
        setTimeout(() => {
            card.style.transition = 'all 0.5s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 100);
    });

    // animation when hovering over the hero section

    const hero = document.querySelector('.hero-oven');
    if (hero) {
        hero.addEventListener('mousemove', (e) => {
            const rect = hero.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width;
            const y = (e.clientY - rect.top) / rect.height;
            hero.style.background = `radial-gradient(circle at ${x * 100}% ${y * 100}%, #8B4000, #2e1a0a)`;
        });
        hero.addEventListener('mouseleave', () => {
            hero.style.background = '';
        });
    }
</script>
    
<style>
    .ripple-effect {
        position: absolute;
        border-radius: 50%;
        background: rgba(245, 197, 66, 0.4);
        width: 10px;
        height: 10px;
        animation: rippleAnim 0.5s ease-out forwards;
        pointer-events: none;
    }

   
    
</style>