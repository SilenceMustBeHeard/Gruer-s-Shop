@using GruersShop.Web.ViewModels.Interactions
@model ReviewListViewModel

@{
    ViewData["Title"] = "Customer Reviews - Gruers Bakery";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="warm-card p-4" data-aos="fade-up">
                
                <!-- Header with Bakery Magic -->
                <div class="text-center mb-4">
                    <div class="reviews-header">
                        <div class="header-icon-wrapper">
                            <i class="bi bi-chat-heart-fill display-1 text-warm"></i>
                            <div class="flour-dust">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                            </div>
                        </div>
                        <h1 class="display-4 mt-2 fw-bold">Customer <span class="text-warm">Reviews</span></h1>
                        <div class="honey-accent mx-auto"></div>
                        <p class="text-muted">What our lovely customers say about us</p>
                    </div>
                </div>

                <!-- Back Button -->
                <div class="mb-4">
                    <a asp-area="Admin" asp-controller="CatalogManagement" asp-action="AdminIndex" class="btn-warm-sm back-btn">
                        <i class="bi bi-arrow-left me-1"></i> Back to Catalog
                    </a>
                </div>

                @if (!Model.Reviews.Any())
                {
                    <div class="text-center py-5 empty-state">
                        <i class="bi bi-chat display-4 text-muted"></i>
                        <p class="mt-3">No reviews yet.</p>
                        <p class="small text-muted">Be the first to share your experience! ⭐</p>
                    </div>
                }
                else
                {
                    <!-- Reviews List -->
                    <div class="reviews-list">
                        @for (int i = 0; i < Model.Reviews.Count; i++)
                        {
                            var review = Model.Reviews[i];
                            var collapseId = $"review-{i}";

                            <div class="review-item warm-card mb-3" data-aos="fade-up" data-aos-delay="@(i * 50)">
                                <div class="review-header d-flex justify-content-between align-items-start flex-wrap gap-3">
                                    <div class="d-flex gap-3 align-items-center">
                                        <div class="reviewer-avatar">
                                            <i class="bi bi-person-circle fs-1 text-warm"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-0 fw-semibold">@review.UserName</h5>
                                            <div class="star-rating mt-1">
                                                @for (int s = 1; s <= 5; s++)
                                                {
                                                    if (s <= review.Rating)
                                                    {
                                                        <i class="bi bi-star-fill text-warning"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star text-muted"></i>
                                                    }
                                                }
                                                <span class="ms-2 small text-muted">@review.Rating/5</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="review-date">
                                        <i class="bi bi-calendar-heart me-1 text-warm"></i>
                                        <small>@review.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</small>
                                    </div>
                                </div>

                                <div class="review-product mt-3">
                                    <span class="stone-badge">
                                        <i class="bi bi-cake2 me-1"></i> @review.ProductName
                                    </span>
                                </div>

                                <div class="review-comment mt-3">
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p class="text-muted mb-2">
                                            <i class="bi bi-quote text-warm me-1"></i>
                                            @(review.Comment.Length > 100 ? review.Comment.Substring(0, 100) + "..." : review.Comment)
                                        </p>
                                        <button class="read-more-btn" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                            <i class="bi bi-chevron-down me-1"></i> Read Full Review
                                        </button>
                                    }
                                    else
                                    {
                                        <p class="text-muted fst-italic">No comment provided.</p>
                                    }
                                </div>

                                <!-- Collapsible Full Review -->
                                <div class="collapse mt-3" id="@collapseId">
                                    <div class="full-review-card p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong class="text-warm">
                                                <i class="bi bi-chat-heart me-1"></i> Full Review
                                            </strong>
                                            <button class="close-review-btn" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                        <p class="mb-0" style="white-space: pre-wrap; line-height: 1.6;">
                                            @review.Comment
                                        </p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Review Stats Footer -->
                    <div class="text-center mt-4 pt-3">
                        <div class="honey-accent mx-auto mb-3" style="width: 50px;"></div>
                        <div class="d-flex justify-content-center gap-4 flex-wrap">
                            <span class="stone-badge">
                                <i class="bi bi-chat-heart me-1"></i> Total Reviews: @Model.Reviews.Count
                            </span>
                            <span class="stone-badge">
                                <i class="bi bi-star-fill text-warning me-1"></i> 
                                Average Rating: @Model.Reviews.Average(r => r.Rating).ToString("0.0")/5
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🍰 Customer Reviews Loaded!');
        });
    </script>
}