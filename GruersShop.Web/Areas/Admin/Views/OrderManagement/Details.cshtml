@using GruersShop.Web.ViewModels.Orders;

@using GruersShop.Data.Common.Enums
@using GruersShop.Data.Models.Interactions
@model Order

@{
    ViewData["Title"] = $"Order #{Model.Id.ToString().Substring(0, 8)}";
    var stockIssues = ViewBag.StockIssues as List<StockIssue> ?? new();
    var isDeleted = Model.IsDeleted;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <a asp-action="Index" class="btn-warm-sm mb-4">&larr; Back</a>

            <div class="warm-card p-4 @(isDeleted ? "deleted-order" : "")">
                @if (isDeleted)
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-eye-slash me-2"></i>
                        <strong>This order is HIDDEN from customers!</strong>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h3 class="fw-bold">Order #@Model.Id.ToString().Substring(0, 8)</h3>
                        <p><strong>Customer:</strong> @Model.User?.Email</p>
                        <p><strong>Date:</strong> @Model.OrderDate?.ToLocalTime()</p>
                        <p><strong>Pickup:</strong> @Model.PickupDate?.ToLocalTime().ToString("dd MMM yyyy") at @Model.PickupTime</p>
                    </div>
                    <div>
                        <span class="badge @(isDeleted ? "bg-danger" : "bg-success")" style="font-size: 14px; padding: 6px 12px;">
                            @(isDeleted ? "🔒 HIDDEN" : "👁️ VISIBLE")
                        </span>
                    </div>
                </div>

                <hr />

                <h5>Items</h5>
                <table class="table">
                    <thead>
                        <tr><th>Product</th><th>Qty</th><th>Price</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                   

                    @if (stockIssues.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Stock issues:</strong>
                            <ul>
                                @foreach (var i in stockIssues)
                                {
                                    <li>@i.ProductName - need @i.RequestedQuantity, have @i.AvailableStock</li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="d-flex gap-3 mt-4">
                        <!-- Soft Delete Button -->
                        <form asp-action="ToggleActive" method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <button type="submit" class="btn @(isDeleted ? "btn-success" : "btn-outline-danger")"
                                    onclick="return confirm('@(isDeleted ? "Show" : "Finish") order #@Model.Id.ToString().Substring(0, 8)? This will @(isDeleted ? "make it visible" : "hide it from customers")');">
                                <i class="bi @(isDeleted ? "bi-eye" : "bi-eye-slash") me-1"></i>
                                @(isDeleted ? "Show Order" : "Finish Order")
                            </button>
                        </form>

                        <!-- Update Status Form -->
                        <form asp-action="UpdateStatus" method="post" style="flex: 1;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="row">
                                <div class="col-md-4">
                                    <label>New Status</label>
                                    <select name="newStatus" class="form-select warm-input">
                                        @foreach (var status in Enum.GetValues<OrderStatus>())
                                        {
                                            <option value="@status" selected="@(Model.Status == status)">@status</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label>Delay (days)</label>
                                    <input type="number" name="delayDays" class="form-control warm-input" value="1" min="1" />
                                </div>
                                <div class="col-md-5">
                                    <label>Cancel reason</label>
                                    <input type="text" name="reason" class="form-control warm-input" placeholder="Required for cancellation" />
                                </div>
                            </div>
                            <button type="submit" class="btn-glow mt-3">Update Status</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

      