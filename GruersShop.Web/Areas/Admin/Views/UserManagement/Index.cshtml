@using GruersShop.Web.ViewModels.Admin
@using Microsoft.AspNetCore.Identity
@model IEnumerable<UserManagmentIndexViewModel>

@inject RoleManager<IdentityRole> RoleManager;

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5">
    <div class="warm-card p-4">
        <div class="text-center mb-4">
            <i class="bi bi-people display-1 text-warm"></i>
            <h1 class="display-4 mt-2">User Management</h1>
            <div class="honey-accent mx-auto"></div>
            <p class="text-muted">Manage platform users and their roles</p>
        </div>

        <div class="mb-4">
            <a asp-area="Admin" asp-controller="AdminDashboard" asp-action="Index" class="btn-warm-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people display-4 text-muted"></i>
                <p class="mt-3">No users available.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var user in Model)
                {
                    var isBanned = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow;

                    <div class="col-lg-4 col-md-6">
                        <div class="warm-card h-100 position-relative @(isBanned ? "opacity-75" : "")">
                            @if (isBanned)
                            {
                                <div class="position-absolute top-0 start-0 w-100 text-center py-2 bg-danger text-white fw-bold rounded-top">
                                    <i class="bi bi-ban me-1"></i> USER BANNED
                                </div>
                            }

                            <div class="card-body d-flex flex-column @(isBanned ? "pt-5" : "pt-3")">
                                <div class="text-center mb-3">
                                    <div class="profile-avatar-sm mx-auto mb-2">
                                        <i class="bi bi-person-circle display-4 text-warm"></i>
                                    </div>
                                    <h5 class="fw-bold mb-1">@user.Email</h5>
                                </div>

                                <div class="mb-3 d-flex flex-wrap gap-2 justify-content-center">
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="stone-badge">@role</span>
                                    }
                                </div>

                                @if (!user.Roles.Contains("Admin"))
                                {
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Change Role</label>
                                        <select name="NewRole" class="form-select warm-input" id="roleSelect-@user.Id">
                                            <option value="">-- Select Role --</option>
                                            @foreach (var role in RoleManager.Roles)
                                            {
                                                <option value="@role.Name">@role.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 mt-auto">
                                        <!-- Assign Role Form - АБСОЛЮТЕН URL -->
                                        <form method="post"
                                              action="/Admin/UserManagement/AssignRole"
                                              class="flex-fill">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="UserId" value="@user.Id" />
                                            <button type="submit"
                                                    class="btn-glow-sm w-100"
                                                    onclick="document.querySelector('input[name=NewRole]').value = document.getElementById('roleSelect-@user.Id').value"
                                                @(isBanned ? "disabled" : "")>
                                                <i class="bi bi-person-plus-fill me-1"></i> Assign
                                            </button>
                                        </form>

                                        <!-- Ban/Unban User Form - АБСОЛЮТЕН URL -->
                                        <form method="post"
                                              action="/Admin/UserManagement/DisableUser"
                                              class="flex-fill">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button class="btn-warm-sm w-100"
                                                    style="background: #dc3545; border-color: #dc3545;"
                                                @(isBanned ? "disabled" : "")>
                                                <i class="bi bi-person-x me-1"></i> Ban
                                            </button>
                                        </form>

                                        <!-- Send Message Form -->
                                        <form method="get"
                                              action="/Admin/SystemMessage/Create"
                                              class="flex-fill">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit"
                                                    class="btn-warm-sm w-100"
                                                @(isBanned ? "disabled" : "")>
                                                <i class="bi bi-envelope me-1"></i> Message
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted mt-2">
                                        <i class="bi bi-shield-lock me-1"></i> Cannot edit Admin
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .profile-avatar-sm {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--wood-light), var(--wood-medium));
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    
    .stone-badge {
        background: var(--stone-medium);
        color: var(--wood-very-dark);
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
    }
    
    [data-bs-theme="dark"] .stone-badge {
        background: #5c3a1e;
        color: #e8d9cc;
    }
</style>

@section Scripts {
    <script>
        
        document.querySelectorAll('form[action="/Admin/UserManagement/AssignRole"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                const userId = this.querySelector('input[name="UserId"]').value;
                const select = document.getElementById(`roleSelect-${userId}`);
                const selectedValue = select?.value;
                
                if (!selectedValue) {
                    e.preventDefault();
                    alert('Моля, изберете роля първо!');
                    return false;
                }
                
             
                let hiddenInput = this.querySelector('input[name="NewRole"]');
                if (!hiddenInput) {
                    hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'NewRole';
                    this.appendChild(hiddenInput);
                }
                hiddenInput.value = selectedValue;
            });
        });
    </script>
}