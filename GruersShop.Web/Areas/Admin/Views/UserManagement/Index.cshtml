@using GruersShop.Web.ViewModels.Admin
@using Microsoft.AspNetCore.Identity
@model IEnumerable<UserManagmentIndexViewModel>

@inject RoleManager<IdentityRole> RoleManager;

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5">
    <h2 class="text-center mb-4">User Management</h2>

    @if (!Model.Any())
    {
        <p class="text-center">No users available.</p>
    }
    else
    {
        <div class="row g-4">
            @foreach (var user in Model)
            {
                var isBanned = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow;

                <div class="col-md-4">
                    <div class="card p-3 @(isBanned ? "bg-light opacity-75" : "")">

                        <h5>@user.Email</h5>

                        <div class="mb-2">
                            Roles:
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge bg-secondary">@role</span>
                            }
                        </div>

                        @if (!user.Roles.Contains("Admin"))
                        {
                            <!-- ✅ Assign Role -->
                            <form method="post"
                                  asp-action="AssignRole"
                                  asp-controller="UserManagement"
                                  asp-area="Admin">

                                <input type="hidden" name="UserId" value="@user.Id" />

                                <select name="NewRole" class="form-select mb-2" @(isBanned ? "disabled" : "")>
                                    @foreach (var role in RoleManager.Roles)
                                    {
                                        <option value="@role.Name"
                                                selected="@(user.Roles.Contains(role.Name) ? "selected" : null)">
                                            @role.Name
                                        </option>
                                    }
                                </select>

                                <button type="submit"
                                        class="btn btn-primary w-100 mb-2"
                                    @(isBanned ? "disabled" : "")>
                                    Assign Role
                                </button>
                            </form>

                            <!-- ✅ Ban User -->
                            <form method="post"
                                  asp-action="DisableUser"
                                  asp-controller="UserManagement"
                                  asp-area="Admin">

                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />

                                <button type="submit"
                                        class="btn btn-danger w-100"
                                    @(isBanned ? "disabled" : "")>
                                    Ban User
                                </button>
                            </form>
                        }
                        else
                        {
                            <p class="text-muted">Cannot edit Admin</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>