@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5">
    <div class="warm-card p-4">
        <div class="text-center mb-4">
            <i class="bi bi-people display-1 text-warm"></i>
            <h1 class="display-4 mt-2">User Management</h1>
            <div class="honey-accent mx-auto"></div>
            <p class="text-muted">Manage users and their roles</p>
        </div>

        <div class="alert-oven alert-info">
            <i class="bi bi-info-circle me-2"></i>
            User management features coming soon!
        </div>

        <div class="text-center mt-4">
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn-warm">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>