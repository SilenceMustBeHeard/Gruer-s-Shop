@{
    ViewData["Title"] = "Bad Request";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card glassmorphism-card text-center p-5 animate__animated animate__fadeInUp">
                
                @* Error image *@
                <div class="error-image-container mb-4">
                    <img src="~/images/errors/bad-request.png"
                         alt="Bad Request"
                         class="img-fluid"
                         style="max-height: 220px;"
                         onerror="this.onerror=null; this.src='https://via.placeholder.com/300x220/2c3e50/ffffff?text=❌+Bad+Request'">
                    </div>

                    <div class="error-badge bg-warning bg-opacity-10 text-warning px-3 py-1 rounded-pill d-inline-block mx-auto mb-3">
                        <small>⚠️ ERROR @(ViewBag.ErrorCode ?? 400)</small>
                    </div>

                    <h1 class="display-5 fw-bold text-warning mb-3">
                        <span class="d-block">❌ Bad Request</span>
                    </h1>

                    <p class="text-muted mb-4">The request could not be understood by the server due to malformed syntax.</p>

                    <div class="suggestions-box mb-4">
                        <h5 class="text-muted mb-3">You might want to:</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-arrow-right-circle text-primary me-2"></i>
                                Check the URL for typos
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-arrow-right-circle text-primary me-2"></i>
                                Clear your browser cache and cookies
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-arrow-right-circle text-primary me-2"></i>
                                Try accessing from a different browser
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-primary btn-lg px-4 hover-scale">
                            <i class="bi bi-house-door me-2"></i>Back to Home
                        </a>
                        <a asp-controller="Home"
                               asp-action="Contact"
                               class="btn btn-outline-primary btn-lg px-4 hover-scale">
                            <i class="bi bi-envelope me-2"></i>Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>