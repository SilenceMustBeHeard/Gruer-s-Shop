﻿@{
ViewData["Title"] = "Bad Request - Gruers Bakery";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="warm-card p-5 text-center bakery-error-card" id="errorCard">
                
                <!-- Animated bakery elements -->
                <div class="bakery-floaties">
                    <i class="bi bi-cookie floating-1"></i>
                    <i class="bi bi-cup-straw floating-2"></i>
                    <i class="bi bi-egg-fried floating-3"></i>
                </div>

                <div class="error-icon-wrapper mb-4">
                    <div class="bakery-oven-glow">
                        <i class="bi bi-exclamation-triangle-fill display-1 text-warning"></i>
                    </div>
                    <div class="smoke-animation">
                        <i class="bi bi-cloud-fill"></i>
                        <i class="bi bi-cloud-fill"></i>
                        <i class="bi bi-cloud-fill"></i>
                    </div>
                </div>

                <div class="error-badge mb-3">
                    <span class="honey-badge pulse-badge">
                        <i class="bi bi-egg-fried me-1"></i> 400 - Bad Request
                    </span>
                </div>

                <h1 class="display-4 fw-bold mb-3" style="color: var(--wood-dark);">
                    Oops! <span class="text-warm">That didn't rise right</span> 🥐
                </h1>

                <p class="text-muted mb-4">The request got a bit crumbled like overworked dough. Let's try a fresh batch!</p>

                <div class="suggestions-box warm-card p-4 mb-4 text-start">
                    <h6 class="text-warm mb-3">
                        <i class="bi bi-chef-hat me-2"></i> Baker's Tips:
                    </h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-arrow-right-circle text-warm me-2"></i>
                            Check your URL for any baking typos
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-arrow-right-circle text-warm me-2"></i>
                            Clear your browser's cookie crumbs
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-arrow-right-circle text-warm me-2"></i>
                            Try a fresh batch from a different browser
                        </li>
                    </ul>
                </div>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn-glow" id="homeBtn">
                        <i class="bi bi-house-heart me-2"></i> Back to Bakery
                    </a>
                    <button onclick="history.back()" class="btn-warm" id="backBtn">
                        <i class="bi bi-arrow-return-left me-2"></i> Try Previous
                    </button>
                </div>

                <div class="mt-4">
                    <small class="text-muted">
                        <i class="bi bi-heart-fill text-danger me-1" style="font-size: 0.7rem;"></i>
                        Freshly baked at Gruers Bakery
                        <i class="bi bi-heart-fill text-danger ms-1" style="font-size: 0.7rem;"></i>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('🍪 Bakery Error Page - Bad Request');
        
        // Add confetti crumbs on page load
        createCrumbConfetti();
        
        // Animate buttons on hover
        const buttons = document.querySelectorAll('.btn-glow, .btn-warm');
        buttons.forEach(btn => {
            btn.addEventListener('mouseenter', function(e) {
                this.style.transform = 'translateY(-2px)';
                this.style.transition = 'all 0.3s ease';
            });
            btn.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
        
        function createCrumbConfetti() {
            const crumbs = ['🍪', '🥐', '🍰', '🧁', '🥖'];
            for(let i = 0; i < 20; i++) {
                setTimeout(() => {
                    const crumb = document.createElement('div');
                    crumb.innerHTML = crumbs[Math.floor(Math.random() * crumbs.length)];
                    crumb.style.position = 'fixed';
                    crumb.style.left = Math.random() * 100 + '%';
                    crumb.style.top = '-20px';
                    crumb.style.fontSize = '1rem';
                    crumb.style.opacity = '0.6';
                    crumb.style.pointerEvents = 'none';
                    crumb.style.zIndex = '9999';
                    crumb.style.animation = `crumbFall ${Math.random() * 2 + 2}s linear forwards`;
                    document.body.appendChild(crumb);
                    
                    setTimeout(() => crumb.remove(), 4000);
                }, i * 100);
            }
        }
        
        // Add crumbFall animation
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes crumbFall {
                0% {
                    transform: translateY(0) rotate(0deg);
                    opacity: 0.6;
                }
                100% {
                    transform: translateY(100vh) rotate(360deg);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
    });
</script>