﻿@{
ViewData["Title"] = "Page Not Found - Gruers Bakery";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="warm-card p-5 text-center bakery-error-card" id="errorCard">
                
                <!-- Animated lost bakery items -->
                <div class="lost-items-container mb-4">
                    <div class="searching-light">
                        <i class="bi bi-search display-1 text-warm"></i>
                    </div>
                    <div class="lost-items">
                        <i class="bi bi-cake2 lost-item-1"></i>
                        <i class="bi bi-cup-straw lost-item-2"></i>
                        <i class="bi bi-egg-fried lost-item-3"></i>
                    </div>
                </div>

                <div class="error-badge mb-3">
                    <span class="honey-badge pulse-badge">
                        <i class="bi bi-compass me-1"></i> 404 - Lost Recipe
                    </span>
                </div>

                <h1 class="display-1 fw-bold mb-0" style="color: var(--honey-gold);">404</h1>
                <h2 class="h3 fw-bold mb-3" style="color: var(--wood-dark);">This recipe seems to be missing! 🥺</h2>

                <p class="text-muted mb-2">We've searched every shelf in our bakery, but couldn't find this page.</p>
                <p class="text-muted mb-4">Maybe it's still in the oven? Let's find you something delicious instead!</p>

                <div class="search-box mb-4">
                    <form asp-controller="Home" asp-action="Search" method="get" class="d-flex gap-2">
                        <input type="text" name="query" class="form-control warm-input"
                               placeholder="Search our bakery..." aria-label="Search" id="searchInput">
                        <button type="submit" class="btn-glow" id="searchBtn">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                </div>

                <div class="popular-links warm-card p-3 mb-4">
                    <h6 class="text-warm mb-2">
                        <i class="bi bi-stars me-1"></i> Popular Recipes:
                    </h6>
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a asp-controller="Home" asp-action="Index" class="stone-badge text-decoration-none">Home</a>
                        <a asp-controller="Products" asp-action="Index" class="stone-badge text-decoration-none">Our Bakery</a>
                        <a asp-controller="Contact" asp-action="Index" class="stone-badge text-decoration-none">Contact Baker</a>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn-glow">
                        <i class="bi bi-house-heart me-2"></i> Back to Bakery
                    </a>
                    <button onclick="history.back()" class="btn-warm">
                        <i class="bi bi-arrow-return-left me-2"></i> Go Back
                    </button>
                </div>

                <div class="mt-4">
                    <small class="text-muted">
                        <i class="bi bi-heart-fill text-danger me-1" style="font-size: 0.7rem;"></i>
                        Freshly baked at Gruers Bakery
                        <i class="bi bi-heart-fill text-danger ms-1" style="font-size: 0.7rem;"></i>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('🔍 Bakery Error Page - 404 Not Found');
        
        const searchInput = document.getElementById('searchInput');
        const searchBtn = document.getElementById('searchBtn');
        
        // Animate search input on focus
        if (searchInput) {
            searchInput.addEventListener('focus', function() {
                this.style.transform = 'scale(1.02)';
                this.style.transition = 'all 0.3s ease';
                this.style.boxShadow = '0 0 0 3px rgba(245, 197, 66, 0.2)';
            });
            
            searchInput.addEventListener('blur', function() {
                this.style.transform = 'scale(1)';
                this.style.boxShadow = '';
            });
            
            // Typewriter effect placeholder
            const placeholders = ['Search for croissants...', 'Looking for cakes?', 'Fresh bread?', 'Pastries?'];
            let index = 0;
            
            setInterval(() => {
                if (!searchInput.value) {
                    searchInput.placeholder = placeholders[index];
                    index = (index + 1) % placeholders.length;
                }
            }, 3000);
        }
        
        // Add hover effect to popular links
        const links = document.querySelectorAll('.stone-badge');
        links.forEach(link => {
            link.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px)';
                this.style.transition = 'all 0.2s ease';
            });
            link.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    });
</script>