@using GruersShop.Web.ViewModels.Error;
@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="warm-card text-center p-5">
                <i class="bi bi-shield-exclamation display-1 text-danger"></i>
                <h1 class="display-4 mt-3">Oops!</h1>
                <div class="honey-accent mx-auto"></div>
                <p class="lead mt-3">An error occurred while processing your request.</p>

                @if (Model.ShowRequestId)
                {
                    <p class="text-muted">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }

                <div class="alert-oven alert-warning mt-4">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Development Mode:</strong> Swapping to <strong>Development</strong> environment will display more detailed information.
                </div>

                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn-glow mt-4">
                    <i class="bi bi-house-heart me-1"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>