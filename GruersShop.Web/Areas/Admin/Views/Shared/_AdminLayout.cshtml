<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Theme styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark py-2">
            <div class="container">
                <!-- Logo -->
                <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-shield-lock fs-2 text-warm"></i>
                        <div>
                            <span class="brand-name" style="font-family: var(--font-serif); font-size: 1.4rem; font-weight: 600; display: block; line-height: 1.2;">Admin Panel</span>
                            <span class="brand-subtitle" style="font-size: 0.65rem; opacity: 0.8; letter-spacing: 1px;">Gruer's Bakery</span>
                        </div>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Admin Navigation -->
                    <div class="mx-auto d-flex justify-content-center">
                        <div class="d-flex gap-3">
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="nav-link-warm">
                                <i class="bi bi-speedometer2 me-1"></i> Dashboard
                            </a>
                            <a asp-area="Admin" asp-controller="CategoryManagement" asp-action="EditList" class="nav-link-warm">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i> Catalog
                            </a>
                            <a asp-area="Admin" asp-controller="AdminProfile" asp-action="AdminInbox" class="nav-link-warm">
                                <i class="bi bi-envelope-paper me-1"></i> Messages
                            </a>
                            <a asp-area="Admin" asp-controller="AdminProfile" asp-action="Index" class="nav-link-warm">
                                <i class="bi bi-person-badge me-1"></i> Profile
                            </a>
                        </div>
                    </div>

                    <!-- Account Dropdown -->
                    <div class="d-flex gap-2 align-items-center">
                        <div class="dropdown">
                            <button class="btn-warm dropdown-toggle d-flex align-items-center gap-1" data-bs-toggle="dropdown" style="padding: 0.4rem 1rem;">
                                <i class="bi bi-person-circle"></i>
                                <span>Admin</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="min-width: 220px;">
                                <li>
                                    <a class="dropdown-item" asp-area="Admin" asp-controller="AdminProfile" asp-action="Index">
                                        <i class="bi bi-person-badge me-2 text-warm"></i> My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="Admin" asp-controller="AdminProfile" asp-action="AdminInbox">
                                        <i class="bi bi-envelope-paper me-2 text-warm"></i> Messages
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li class="px-3 py-2">
                                    <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-warm w-100">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Alert Messages -->
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert-oven alert-success" role="alert">
                    <i class="bi bi-fire me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close-oven" data-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert-oven alert-danger" role="alert">
                    <i class="bi bi-emoji-frown me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close-oven" data-dismiss="alert"></button>
                </div>
            }
        </div>
    </header>

    <!-- Main Content -->
    <main class="hearth-container">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer-stone mt-auto py-4">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year - Gruer's Artisanal Bakery | Admin Panel</p>
            <small class="text-muted">"Where every bite tells a story"</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>