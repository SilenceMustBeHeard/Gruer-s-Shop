<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gruer's Bakery Admin</title>
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- Google Fonts for warm typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <!-- Theme styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/badges.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/navigation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/error.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/dark.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/light.css" asp-append-version="true" />
    
 
</head>

<body>
    <canvas id="sparksCanvas"></canvas>
    
    <!-- Floating bakery items in background -->
    <div id="floatingItems"></div>
    
    <!-- Admin Loading Overlay -->
    <div class="admin-loading-overlay" id="adminLoadingOverlay">
        <div class="loading-spinner-bakery"></div>
        <div class="text-warm">Baking your request... 🍪</div>
    </div>
    
    <header>
        <!-- Navbar with proper overflow -->
        <nav class="navbar navbar-expand-lg navbar-dark py-2" id="mainNav">
            <div class="container">
                <!-- Logo / Brand -->
                <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center gap-2">
                        <div class="logo-wrapper">
                            <i class="bi bi-egg-fried fs-2 text-warm logo-icon"></i>
                            <i class="bi bi-stars logo-sparkle"></i>
                        </div>
                        <div>
                            <span class="brand-baked">Gruer’s</span>
                            <span class="brand-subtitle">Artisanal Bakery</span>
                        </div>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Center Navigation -->
                    <div class="mx-auto d-flex justify-content-center">
                        @await Component.InvokeAsync("Navbar")
                    </div>

                    <!-- Right Side - Account area -->
                    <div class="d-flex gap-2 align-items-center">
                        <!-- Bakery Time Display -->
                        <div class="bakery-time d-none d-md-flex align-items-center gap-2">
                            <i class="bi bi-clock-history text-warm"></i>
                            <span id="bakeryTime">--:--</span>
                        </div>
                        
                        <!-- Theme Toggle Button -->
                        <button class="theme-toggle" id="themeToggleBtn" title="Toggle theme">
                            <i class="bi bi-moon-stars" id="themeIcon"></i>
                        </button>

                        <!-- Account Dropdown with highest z-index -->
                        <div class="dropdown" id="accountDropdown">
                            <button class="btn-warm dropdown-toggle d-flex align-items-center gap-1" 
                                    type="button"
                                    id="accountDropdownButton"
                                    data-bs-toggle="dropdown" 
                                    data-bs-auto-close="outside"
                                    aria-expanded="false"
                                    style="padding: 0.4rem 1rem;">
                                <i class="bi bi-person-circle"></i>
                                <span>Account</span>
                                <i class="bi bi-chevron-down small"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" 
                                aria-labelledby="accountDropdownButton">
                                @await Component.InvokeAsync("AccountMenu")
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Toast Container for notifications -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
        </div>

    </header>

    <!-- Main Content -->
    <main class="hearth-container">
        <div class="container py-4">
            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Index" && 
                 ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard")
            {
                <div class="welcome-message mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-emoji-smile fs-1 text-warm"></i>
                        <div>
                            <h4 class="mb-0">Welcome back, Master Baker! 👨‍🍳</h4>
                            <p class="text-muted small mb-0">Ready to create some magic today?</p>
                        </div>
                    </div>
                </div>
            }
            
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer-stone mt-auto py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start">
                    <p class="mb-0">&copy; @DateTime.Now.Year - Gruer's Artisanal Bakery</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="d-flex justify-content-center gap-3">
                        <i class="bi bi-heart-fill text-danger"></i>
                        <small class="text-muted">"Where every bite tells a story"</small>
                        <i class="bi bi-heart-fill text-danger"></i>
                    </div>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <div class="social-links">
                        <a href="#" class="text-muted me-2"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-muted me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-muted"><i class="bi bi-pinterest"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!--hidden fields for TempData -->
    <input type="hidden" id="tempDataSuccess" value="@TempData["Success"]" />
    <input type="hidden" id="tempDataError" value="@TempData["Error"]" />
    <input type="hidden" id="tempDataWarning" value="@TempData["Warning"]" />
    <input type="hidden" id="tempDataInfo" value="@TempData["Info"]" />

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/oven.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/toast-notifications.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize AOS
            AOS.init({
                duration: 800,
                once: true,
                offset: 100
            });
            
            // Force dropdown to be on top
            const dropdownElement = document.querySelector('#accountDropdown');
            const dropdownMenu = document.querySelector('#accountDropdown .dropdown-menu');
            const dropdownButton = document.querySelector('#accountDropdownButton');
            
            if (dropdownElement && dropdownMenu) {
                // Ensure dropdown has highest z-index when opened
                dropdownButton.addEventListener('show.bs.dropdown', function() {
                    dropdownMenu.style.zIndex = '9999999';
                    dropdownMenu.style.position = 'absolute';
                    dropdownMenu.style.display = 'block';
                    
                    // Force reposition on viewport edge
                    const rect = dropdownMenu.getBoundingClientRect();
                    const viewportWidth = window.innerWidth;
                    
                    if (rect.right > viewportWidth) {
                        dropdownMenu.style.right = '0';
                        dropdownMenu.style.left = 'auto';
                    }
                });
                
                dropdownButton.addEventListener('shown.bs.dropdown', function() {
                    // Check if dropdown goes off screen
                    const rect = dropdownMenu.getBoundingClientRect();
                    const viewportHeight = window.innerHeight;
                    
                    if (rect.bottom > viewportHeight) {
                        dropdownMenu.style.maxHeight = (viewportHeight - rect.top - 20) + 'px';
                        dropdownMenu.style.overflowY = 'auto';
                    }
                });
                
                dropdownButton.addEventListener('hide.bs.dropdown', function() {
                    dropdownMenu.style.maxHeight = '';
                    dropdownMenu.style.overflowY = '';
                });
            }
            
            // Bakery Time Display
            function updateBakeryTime() {
                const now = new Date();
                const timeString = now.toLocaleTimeString('en-US', { 
                    hour: '2-digit', 
                    minute: '2-digit',
                    hour12: true 
                });
                const timeElement = document.getElementById('bakeryTime');
                if (timeElement) {
                    timeElement.textContent = timeString;
                }
            }
            updateBakeryTime();
            setInterval(updateBakeryTime, 1000);
            
            // Theme Toggle
            const themeToggle = document.getElementById('themeToggleBtn');
            const themeIcon = document.getElementById('themeIcon');
            const htmlElement = document.documentElement;
            
            function setTheme(theme) {
                htmlElement.setAttribute('data-bs-theme', theme);
                localStorage.setItem('bakery-theme', theme);
                if (theme === 'dark') {
                    themeIcon.className = 'bi bi-moon-stars';
                } else {
                    themeIcon.className = 'bi bi-sun';
                }
            }
            
            const savedTheme = localStorage.getItem('bakery-theme') || 'dark';
            setTheme(savedTheme);
            
            if (themeToggle) {
                themeToggle.addEventListener('click', () => {
                    const currentTheme = htmlElement.getAttribute('data-bs-theme');
                    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                    setTheme(newTheme);
                    themeToggle.style.transform = 'scale(1.1)';
                    setTimeout(() => {
                        themeToggle.style.transform = 'scale(1)';
                    }, 200);
                });
            }
            
            // Create floating bakery items
            const bakeryItems = ['🍪', '🥐', '🍰', '🧁', '🥖', '🍞', '🥨', '🧀'];
            const floatingContainer = document.getElementById('floatingItems');
            
            for (let i = 0; i < 15; i++) {
                const item = document.createElement('div');
                item.className = 'floating-bakery-item';
                item.innerHTML = bakeryItems[Math.floor(Math.random() * bakeryItems.length)];
                item.style.left = Math.random() * 100 + '%';
                item.style.animationDuration = (Math.random() * 20 + 15) + 's';
                item.style.animationDelay = Math.random() * 10 + 's';
                item.style.fontSize = (Math.random() * 2 + 1.5) + 'rem';
                floatingContainer.appendChild(item);
            }
            
            // Auto-dismiss alerts
            const alerts = document.querySelectorAll('.alert-oven');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.animation = 'fadeOut 0.5s ease';
                    setTimeout(() => {
                        if (alert && alert.remove) alert.remove();
                    }, 500);
                }, 5000);
            });
            
            // Loading overlay for form submissions
            const forms = document.querySelectorAll('form');
            forms.forEach(form => {
                form.addEventListener('submit', function() {
                    const overlay = document.getElementById('adminLoadingOverlay');
                    if (overlay) {
                        overlay.classList.add('active');
                    }
                });
            });
            
            // Keyboard shortcuts
            document.addEventListener('keydown', (e) => {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                    return;
                }
                
                if (e.altKey && e.key === 'd') {
                    e.preventDefault();
                    window.location.href = '/Admin/AdminDashboard';
                }
                if (e.altKey && e.key === 'p') {
                    e.preventDefault();
                    window.location.href = '/Admin/AdminProfile';
                }
                if (e.altKey && e.key === 'i') {
                    e.preventDefault();
                    window.location.href = '/Admin/AdminInbox';
                }
                if (e.altKey && e.key === 'h') {
                    e.preventDefault();
                    window.location.href = '/';
                }
            });
            
            // Add hover effect to cards
            const cards = document.querySelectorAll('.warm-card, .dashboard-card, .message-card');
            cards.forEach(card => {
                card.classList.add('hover-lift');
            });
            
            console.log('🍰 Gruers Bakery Admin Panel Loaded');
            console.log('👨‍🍳 Ready to bake some magic!');
            console.log('💡 Tip: Use Alt+D (Dashboard), Alt+P (Profile), Alt+I (Inbox)');
        });
       
       
        document.head.appendChild(styleSheet);
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>