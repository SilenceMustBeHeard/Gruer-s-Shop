@model bool

@using GruersShop.Data.Models.Base
@using GruersShop.Services.Core.Service.Interfaces.Interactions
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@inject ICartService CartService

@{
    string displayName = null;
    int cartItemsCount = 0;

    if (Model)
    {
        var user = await UserManager.GetUserAsync(User);
        
        if (!string.IsNullOrEmpty(user?.FirstName))
        {
            displayName = user.FirstName;
        }
        else if (!string.IsNullOrEmpty(user?.UserName))
        {
            displayName = user.UserName?.Split('@')[0];
        }
        else
        {
            displayName = user?.Email;
        }
        
        // Get cart items count
        try
        {
            var cart = CartService.GetCart();
            cartItemsCount = cart.TotalItems;
        }
        catch
        {
            cartItemsCount = 0;
        }
    }
}

@if (Model)
{
    <li class="dropdown-header border-bottom mb-2 pb-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-egg-fried text-warm"></i>
            <div>
                <small class="text-muted d-block">Welcome back,</small>
                <strong class="text-glow">@displayName</strong>
            </div>
        </div>
    </li>

    @if (!User.IsInRole("Admin") && !User.IsInRole("Manager"))
    {

    <!-- Profile Link (for all logged in users) -->
    <li>
        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
            <i class="bi bi-person-badge me-2 text-warm"></i> My Profile
        </a>
    </li>

    <!-- My Orders Link (for all logged in users) -->
    <li>
        <a class="dropdown-item" asp-controller="Orders" asp-action="MyOrders">
            <i class="bi bi-receipt me-2 text-warm"></i> My Orders
        </a>
    </li>

    <!-- Cart Link with badge -->
    <li>
        <a class="dropdown-item d-flex justify-content-between align-items-center"
               asp-controller="Cart" asp-action="Index">
            <span>
                <i class="bi bi-cart3 me-2 text-warm"></i> My Cart
            </span>
            @if (cartItemsCount > 0)
            {
                <span class="honey-badge">@cartItemsCount</span>
            }
        </a>
    </li>
    }
    <!-- Admin Dashboard Link (only for admins) -->
    @if (User.IsInRole("Admin"))
    {
        <li><hr class="dropdown-divider"></li>
        <li>
            <a class="dropdown-item" asp-area="Admin" asp-controller="AdminDashboard" asp-action="Index">
                <i class="bi bi-shield-lock me-2 text-warm"></i> Admin Dashboard
            </a>
        </li>
        <li>
            <a class="dropdown-item" asp-area="Admin" asp-controller="AdminProfile" asp-action="Index">
                <i class="bi bi-person-badge me-2 text-warm"></i> Admin Profile
            </a>
        </li>
        <li>
            <a class="dropdown-item" asp-area="Admin" asp-controller="UserManagement" asp-action="Index">
                <i class="bi bi-people me-2 text-warm"></i> User Management
            </a>
        </li>
    }

    <!-- Manager Links -->
    @if (User.IsInRole("Manager"))
    {
        <li><hr class="dropdown-divider"></li>
        <li>
            <a class="dropdown-item" asp-area="Manager" asp-controller="Home" asp-action="Index">
                <i class="bi bi-clipboard-data me-2 text-warm"></i> Manager Dashboard
            </a>
        </li>
    }

    <li><hr class="dropdown-divider"></li>

    <!-- Logout -->
    <li class="px-3 py-2">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-warm w-100">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="dropdown-header border-bottom mb-2 pb-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-cup-hot text-warm"></i>
            <small class="text-muted">Welcome to Gruer's</small>
        </div>
    </li>

    <li>
        <a class="dropdown-item" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right me-2 text-warm"></i> Login
        </a>
    </li>

    <li>
        <a class="dropdown-item" asp-controller="Account" asp-action="Register">
            <i class="bi bi-person-plus me-2 text-warm"></i> Register
        </a>
    </li>
}