@model bool

@using GruersShop.Data.Models.Base
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    string displayName = null;

    if (Model)
    {
        var user = await UserManager.GetUserAsync(User);
        
        if (!string.IsNullOrEmpty(user?.FirstName))
        {
            displayName = user.FirstName;
        }
        else if (!string.IsNullOrEmpty(user?.UserName))
        {
            displayName = user.UserName?.Split('@')[0];
        }
        else
        {
            displayName = user?.Email;
        }
    }
}

@if (Model)
{
    <li class="dropdown-header border-bottom mb-2 pb-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-egg-fried text-warm"></i>
            <div>
                <small class="text-muted d-block">Welcome back,</small>
                <strong class="text-glow">@displayName</strong>
            </div>
        </div>
    </li>

    <!-- Profile Link -->
    <li>
        <a class="dropdown-item" asp-area="Admin" asp-controller="AdminProfile" asp-action="Index">
            <i class="bi bi-person-badge me-2 text-warm"></i> My Profile
        </a>
    </li>

    <!-- Admin Dashboard Link (only for admins) -->
    @if (User.IsInRole("Admin"))
    {
        <li>
            <a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-lock me-2 text-warm"></i> Admin Dashboard
            </a>
        </li>

        <li>
            <a class="dropdown-item" asp-area="Admin" asp-controller="UserManagement" asp-action="Index">
                <i class="bi bi-shield-lock me-2 text-warm"></i> User Management
            </a>
        </li>
    }

    <li><hr class="dropdown-divider"></li>


    <!-- Logout -->
    <li class="px-3 py-2">
        <form asp-area = "Admin"
            asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-warm w-100">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="dropdown-header border-bottom mb-2 pb-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-cup-hot text-warm"></i>
            <small class="text-muted">Welcome to Gruer's</small>
        </div>
    </li>

    <li>
        <a class="dropdown-item" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right me-2 text-warm"></i> Login
        </a>
    </li>

    <li>
        <a class="dropdown-item" asp-controller="Account" asp-action="Register">
            <i class="bi bi-person-plus me-2 text-warm"></i> Register
        </a>
    </li>
}