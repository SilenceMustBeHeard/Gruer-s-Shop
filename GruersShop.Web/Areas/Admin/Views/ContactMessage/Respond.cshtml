@using GruersShop.Web.ViewModels.Admin.Message
@model ContactMessageResponseViewModel

@{
    ViewData["Title"] = "Respond to Customer";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="warm-card p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0">Respond to Customer</h2>
                    <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Details" asp-route-id="@Model.Id" class="btn-warm-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                </div>

                <!-- Original Message -->
                <div class="warm-card mb-4 p-3">
                    <h6 class="text-warm mb-3">Original Message</h6>
                    <div class="mb-2">
                        <strong>From:</strong> @Model.SenderName
                    </div>
                    <div class="mb-2">
                        <strong>Email:</strong> @Model.SenderEmail
                    </div>
                    <div class="mb-2">
                        <strong>Subject:</strong> @Model.Subject
                    </div>
                    <hr class="stone-divider">
                    <div class="story-text p-3 rounded-3" style="background: var(--stone-light);">
                        @Model.OriginalMessage
                    </div>
                </div>

                <!-- Response Form -->
                <form asp-area="Admin" asp-controller="ContactMessage" asp-action="Respond" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Subject" />
                    <input type="hidden" asp-for="SenderName" />
                    <input type="hidden" asp-for="SenderEmail" />
                    <input type="hidden" asp-for="OriginalMessage" />

                    <div class="mb-3">
                        <label asp-for="Response" class="form-label fw-bold">Your Response</label>
                        <textarea asp-for="Response" class="form-control warm-input" rows="8" placeholder="Type your response here..."></textarea>
                        <span asp-validation-for="Response" class="text-danger"></span>
                        <small class="text-muted mt-1 d-block">
                            <i class="bi bi-info-circle me-1"></i> Your response will be sent to the customer's email address.
                        </small>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Details" asp-route-id="@Model.Id" class="btn-warm">
                            Cancel
                        </a>
                        <button type="submit" class="btn-glow">
                            <i class="bi bi-send me-2"></i> Send Response
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}